<UserControl x:Class="DominatorUIUtility.Views.AccountSetting.QueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.AccountSetting"
             mc:Ignorable="d" 
             xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <GroupBox Header="{DynamicResource LangKeySearchQuery}" Margin="5" >
            <customControl:SearchQueryControl ListQueryType="{Binding SaveSettingModel.ListQueryType}" 
                                          ListQueryInfo="{Binding SaveSettingModel.ListQueryInfo}" 
                                          AddQueryCommand="{Binding AddQueryCommand}" CommandParameter="{Binding}" />

        </GroupBox>
        <local:NextPreviousButton Grid.Row="1" NextCommand="{Binding NextCommand}" NextButtonContent="{DynamicResource LangKeyFinish}"
                                  PreviousCommand="{Binding PreviousCommand}" PreviousCommandParameter="JobConfig" />
    </Grid>
</UserControl>
