<UserControl x:Class="DominatorUIUtility.Views.Publisher.AdvancedSettings.Instagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.Publisher.AdvancedSettings"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" >
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid x:Name="MainGrid">
        <ScrollViewer>
            <StackPanel>
                <!--<CheckBox Content="{DynamicResource langCropImageInsteadOfAddingWhiteBorders}" VerticalAlignment="Center" Margin="5"/>
                <CheckBox Content="{DynamicResource langPostAsPartOfStory}" VerticalAlignment="Center" Margin="5"/>
                <CheckBox Content="{DynamicResource langSplitVideosInSmallerParts}" VerticalAlignment="Center" Margin="5"/>
                <CheckBox Content="{DynamicResource langPostOnWallAndInStory}" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="{DynamicResource langDeleteAfter}" VerticalAlignment="Center" Margin="5"/>
                    <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource langHours}" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <CheckBox Content="{DynamicResource langArchivePostInsteadOfDeletingItOnlyForIGPost}" VerticalAlignment="Center" Margin="5"/>
                <CheckBox Content="{DynamicResource langTagSpecificUsers}" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Height="50" Width="300" AcceptsReturn="True" HorizontalAlignment="Left" Margin="30,5" controls:TextBoxHelper.Watermark="{DynamicResource langUserNamesWaterMark}"/>
                    <Button x:Name="btnAddUsernames" Content="{DynamicResource langAddUsernames}" VerticalAlignment="Center" Background="{DynamicResource AccentBaseColorBrush}" Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="{DynamicResource langMaxNumberOfUsersToTag}" VerticalAlignment="Center" Margin="5"/>
                    <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                </StackPanel>
                <CheckBox Content="{DynamicResource langRemoveUserFromListAfterHeIsTagged}" VerticalAlignment="Center" Margin="5"/>
                <Button Margin="10,5" x:Name="btnDeleteAll" Content="{DynamicResource langDeleteAll}" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{DynamicResource AccentBaseColorBrush}" Foreground="White"/>
                <ListView   Margin="5" ItemsSource="{Binding PostsDetailCollection}">
                    <ListView.Resources>
                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View >
                        <GridView >
                            <GridViewColumn Header="{DynamicResource langIndex}" />
                            <GridViewColumn Header="{DynamicResource langUsername}"/>
                            <GridViewColumn Header="{DynamicResource langPrivateYesNo}" />
                            <GridViewColumn Header="{DynamicResource langFollowers}" />
                            <GridViewColumn Header="{DynamicResource langAction}" />
                        </GridView>
                    </ListView.View>

                </ListView>-->
                <CheckBox Content="{DynamicResource langPostusingGeoLocation﻿}"
                          VerticalAlignment="Center" Margin="5" IsChecked="{Binding InstagramModel.IsPostusingGeoLocation}"/>
                <TextBox HorizontalAlignment="Left" Width="200" Margin="30,0" Visibility="{Binding InstagramModel.IsPostusingGeoLocation,
                         Converter={StaticResource BooleanToVisibilityConverter}}"
                         controls:TextBoxHelper.Watermark="{DynamicResource DHlangEnterGeoLocations}"/>
                <CheckBox Content="{DynamicResource langEnableAutomaticHashTags}"
                          VerticalAlignment="Center" Margin="5" IsChecked="{Binding InstagramModel.IsEnableAutomaticHashTags}"/>
                <StackPanel Margin="30,0" Visibility="{Binding InstagramModel.IsEnableAutomaticHashTags,Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource langUseToAddHashInFrontOfKeywords}" VerticalAlignment="Center" Margin="5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource langMaxHashTagsPerPost}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" Value="{Binding InstagramModel.MaxHashtagsPerPost}" />
                    </StackPanel>
                    <GroupBox Header="{DynamicResource langHashByKeyword}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource langAutomaticallyHashAllWords}" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Height="50" Width="300" AcceptsReturn="True"
                                     HorizontalAlignment="Left" Margin="10,5" Text="{Binding InstagramModel.HashWords}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource langHashByMinimumWordLength}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{DynamicResource langMinimumWordLength}" VerticalAlignment="Center" Margin="5"/>
                                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center"
                                                        Value="{Binding InstagramModel.MinimumWordLength}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,0">
                                <TextBlock Text="{DynamicResource langReplaceProbability}" VerticalAlignment="Center" Margin="5"/>
                                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" 
                                                        Value="{Binding InstagramModel.ReplaceProbability}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
                <CheckBox Content="{DynamicResource langEnableDynamicHashTags}"
                          VerticalAlignment="Center" Margin="5"
                          IsChecked="{Binding InstagramModel.IsEnableDynamicHashTags}"/>
                <CheckBox Content="{DynamicResource DHlangAddHashTagEvenIfAlreadyHastags}"
                          VerticalAlignment="Center" Margin="30,0"
                          Visibility="{Binding InstagramModel.IsEnableDynamicHashTags,
                          Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsChecked="{Binding InstagramModel.IsAddHashTagEvenIfAlreadyHastags}"/>
                <StackPanel  Visibility="{Binding InstagramModel.IsAddHashTagEvenIfAlreadyHastags,
                             Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangMaxHashtagsPerPost}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0" Value="{Binding InstagramModel.MaxHashtagsPerPostRange.StartValue}"/>
                        <TextBlock Text="-" VerticalAlignment="Center"/>
                        <controls:NumericUpDown Margin="5" 
                                                Minimum="{Binding InstagramModel.MaxHashtagsPerPostRange.StartValue}"
                                                Value="{Binding InstagramModel.MaxHashtagsPerPostRange.EndValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangPick}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0" Value="{Binding InstagramModel.PickPercentHashTag}"/>
                        <TextBlock Text="{DynamicResource DHlangPercentExtraHashtags}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangPick}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0" Value="{Binding InstagramModel.PickPercentFromList}"/>
                        <TextBlock Text="{DynamicResource DHlangPercentFromList}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <CheckBox Content="{DynamicResource DHlangEnableDynamicMentions}"
                          VerticalAlignment="Center" Margin="5"
                          IsChecked="{Binding InstagramModel.IsEnableDynamicMentions}"/>
                <StackPanel Visibility="{Binding InstagramModel.IsEnableDynamicMentions,
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Content="{DynamicResource DHlangDeleteUsersFromList}"
                              VerticalAlignment="Center" Margin="30,5" IsChecked="{Binding InstagramModel.IsDeleteUsersFromList}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource DHlangNumberOfUsersToMention}" Margin="55,0,5,0"/>
                        <controls:NumericUpDown Minimum="0" Value="{Binding InstagramModel.NumberOfUsersToMention}"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource DHlangAddUsernamesSeparatedByComma}" Margin="55,0,5,0"/>
                    <TextBox Width="230" HorizontalAlignment="Left" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                             Margin="55,5" Height="50" AcceptsReturn="True"
                             Text="{Binding InstagramModel.UserNamesSeparatedByComma}"/>
                </StackPanel>
                <!--<CheckBox Content="{DynamicResource langEnableDynamicMentions}" VerticalAlignment="Center" Margin="5"/>-->

                <CheckBox Content="{DynamicResource langRetryFailedVideoPost}"
                          VerticalAlignment="Center" Margin="5" IsChecked="{Binding InstagramModel.IsRetryFailedVideoPost}"/>

                <CheckBox Content="{DynamicResource langDisableCommentsForNewPost}"
                          VerticalAlignment="Center" Margin="5" IsChecked="{Binding InstagramModel.IsDisableCommentsForNewPost}"/>

                <CheckBox Content="{DynamicResource langPostMultipleImagesVideoPostsAsAlbum}"
                          VerticalAlignment="Center" Margin="5" IsChecked="{Binding InstagramModel.IsPostMultipleImagesVideoPostsAsAlbum}"/>
                <!--<CheckBox Content="{DynamicResource langEnableDirectMediaShare}" VerticalAlignment="Center" Margin="5"/>-->

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
