<UserControl x:Class="DominatorUIUtility.Views.Publisher.AdvancedSettings.Twitter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.Publisher.AdvancedSettings"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" Loaded="Twitter_OnLoaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="5" Name="MainGrid">
        <CheckBox Content="{DynamicResource langEnableAutomaticHashTags}" 
                  VerticalAlignment="Center" Margin="5" IsChecked="{Binding TwitterModel.IsEnableAutomaticHashTags}"/>
        <StackPanel Margin="30,0" 
                    Visibility="{Binding TwitterModel.IsEnableAutomaticHashTags,
                    Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource langUseToAddHashInFrontOfKeywords}" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource langMaxHashTagsPerPost}" VerticalAlignment="Center" Margin="5"/>
                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center"
                                        Value="{Binding TwitterModel.MaxHashtagsPerPost}"/>
            </StackPanel>
            <GroupBox Header="{DynamicResource langHashByKeyword}" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="{DynamicResource langAutomaticallyHashAllWords}" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Height="50" Width="300" AcceptsReturn="True"
                             HorizontalAlignment="Left" Margin="10,5"
                             Text="{Binding TwitterModel.HashWords}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="{DynamicResource langHashByMinimumWordLength}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="{DynamicResource langMinimumWordLength}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center"
                                                Value="{Binding TwitterModel.MinimumWordLength}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                        <TextBlock Text="{DynamicResource langReplaceProbability}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center"
                                                Value="{Binding TwitterModel.ReplaceProbability}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

        </StackPanel>
        <StackPanel Orientation="Horizontal" >
            <CheckBox Content="{DynamicResource langDeletePostAfter}" 
                      VerticalAlignment="Center" Margin="5"
                      IsChecked="{Binding TwitterModel.IsDeletePostAfter}"/>
            <controls:NumericUpDown Margin="5" Minimum="0" IsEnabled="{Binding TwitterModel.IsDeletePostAfter}"
                                    Value="{Binding TwitterModel.DeletePostAfter.StartValue}"/>
            <TextBlock Text="{DynamicResource langTo}" VerticalAlignment="Center"/>
            <controls:NumericUpDown Margin="5"  IsEnabled="{Binding TwitterModel.IsDeletePostAfter}"
                                    Minimum="{Binding TwitterModel.DeletePostAfter.StartValue}"
                                    Value="{Binding TwitterModel.DeletePostAfter.EndValue}"/>
            <TextBlock Text="{DynamicResource langHours}" VerticalAlignment="Center"/>
        </StackPanel>
        <CheckBox Content="{DynamicResource langEnableDynamicHashTags}" 
                  VerticalAlignment="Center" Margin="5"  
                  IsChecked="{Binding TwitterModel.IsEnableDynamicHashTags}"/>
        <CheckBox Content="{DynamicResource DHlangAddHashTagEvenIfAlreadyHastags}"
                  VerticalAlignment="Center" Margin="30,0"
                  IsChecked="{Binding TwitterModel.IsAddHashTagEvenIfAlreadyHastags}"
                  Visibility="{Binding TwitterModel.IsEnableDynamicHashTags,
                  Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <StackPanel Visibility="{Binding TwitterModel.IsAddHashTagEvenIfAlreadyHastags,
                  Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Margin="50,0">
                <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangMaxHashtagsPerPost}"/>
                <controls:NumericUpDown Margin="5" Minimum="0" Value="{Binding TwitterModel.MaxHashtagsPerPostRange.StartValue}"/>
                <TextBlock Text="-" VerticalAlignment="Center"/>
                <controls:NumericUpDown Margin="5"
                                        Minimum="{Binding TwitterModel.MaxHashtagsPerPostRange.StartValue}"
                                        Value="{Binding TwitterModel.MaxHashtagsPerPostRange.EndValue}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="50,0">
                <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangPick}"/>
                <controls:NumericUpDown Margin="5" Minimum="0" 
                                        Value="{Binding TwitterModel.PickPercentHashTag}"/>
                <TextBlock Text="{DynamicResource DHlangPercentExtraHashtags}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="50,0">
                <TextBlock VerticalAlignment="Center" Text="{DynamicResource DHlangPick}"/>
                <controls:NumericUpDown Margin="5" Minimum="0"
                                        Value="{Binding TwitterModel.PickPercentFromList}"/>
                <TextBlock Text="{DynamicResource DHlangPercentFromList}" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        <!--<CheckBox Content="{DynamicResource langAutomaticallyDeletePosts}" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Orientation="Horizontal" Margin="30,0">
                <TextBlock Text="{DynamicResource langDeleteAfter}" VerticalAlignment="Center" Margin="5"/>
                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource langTo}" VerticalAlignment="Center" Margin="5"/>
                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource langHours}" VerticalAlignment="Center" Margin="5"/>
            </StackPanel>-->

    </StackPanel>
</UserControl>
