<UserControl x:Class="DominatorUIUtility.Views.Publisher.AdvancedSettings.Twitter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.Publisher.AdvancedSettings"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             >
    <Grid>
        <StackPanel Margin="5">
            <CheckBox Content="{DynamicResource langEnableAutomaticHashTags}" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Margin="30,0">
                <TextBlock Text="{DynamicResource langUseToAddHashInFrontOfKeywords}" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource langMaxHashTagsPerTweet}" VerticalAlignment="Center" Margin="5"/>
                    <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                </StackPanel>
                <GroupBox Header="{DynamicResource langHashByKeyword}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource langAutomaticallyHashAllWords}" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Height="50" Width="300"  HorizontalAlignment="Left" Margin="10,5"/>
                        <TextBlock Text="{DynamicResource langWarningHashKeyword}" VerticalAlignment="Center" Margin="15,5"/>
                    </StackPanel>
                </GroupBox>
                <CheckBox Content="{DynamicResource langHashByMinimumWordLength}" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Margin="10,0">
                    <StackPanel Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="{DynamicResource langMinimumWordLength}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,5">
                        <TextBlock Text="{DynamicResource langReplaceProbability}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <CheckBox Content="{DynamicResource langAutomaticallyDeletePosts}" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Orientation="Horizontal" Margin="30,0">
                <TextBlock Text="{DynamicResource langDeleteAfter}" VerticalAlignment="Center" Margin="5"/>
                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource langTo}" VerticalAlignment="Center" Margin="5"/>
                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource langHours}" VerticalAlignment="Center" Margin="5"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
