<UserControl x:Class="DominatorUIUtility.Views.Publisher.AdvancedSettings.Tumblr"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.Publisher.AdvancedSettings"
             mc:Ignorable="d" 
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             Loaded="Tumblr_OnLoaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"></BooleanToVisibilityConverter>
    </UserControl.Resources>
    <StackPanel Name="MainGrid">
        <CheckBox Content="{DynamicResource LangKeyRemoveTagsFromPostTextAsTheyAreAddedInTheTagsSectionOnTumblr}" 
                  VerticalAlignment="Center" Margin="5" IsChecked="{Binding TumblrModel.IsRemoveTagsFromPostText}"/>
        <CheckBox Content="{DynamicResource LangKeyEnableAutomaticHashtags}"
                  VerticalAlignment="Center" Margin="5" IsChecked="{Binding TumblrModel.IsEnableAutomaticHashTags}"/>
        <StackPanel Margin="30,0" Visibility="{Binding TumblrModel.IsEnableAutomaticHashTags,
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource LangKeyUseToAddNumOfInFrontOfTheKeywordsThatYouSelectedOrInFrontOfWordsWithALengthGreaterThanAGivenValue}" VerticalAlignment="Center" Margin="5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyMaxHashtagsPerPost}" VerticalAlignment="Center" Margin="5"/>
                        <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" 
                                                Value="{Binding TumblrModel.MaxHashtagsPerPost}"/>
                    </StackPanel>
                    <GroupBox Header="{DynamicResource LangKeyHashByKeyword}" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LangKeyAutomaticallyHashAllTheWordsInTheListBelowAddYourKeywordsSeparatedByCommas}" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Height="50" Width="300" AcceptsReturn="True"
                                     HorizontalAlignment="Left" Margin="10,5"
                                     Text="{Binding TumblrModel.HashWords}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource LangKeyHashByMinimumWordLength}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{DynamicResource LangKeyMinimumWordLength}" VerticalAlignment="Center" Margin="5"/>
                                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center"
                                                        Value="{Binding TumblrModel.MinimumWordLength}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,0">
                                <TextBlock Text="{DynamicResource LangKeyReplaceProbability}" VerticalAlignment="Center" Margin="5"/>
                                <controls:NumericUpDown Minimum="0" VerticalAlignment="Center" 
                                                        Value="{Binding TumblrModel.ReplaceProbability}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
                <CheckBox Content="{DynamicResource LangKeyEnableDynamicHashtags}"
                          VerticalAlignment="Center" Margin="5"
                          IsChecked="{Binding TumblrModel.IsEnableDynamicHashTags}"/>
                <CheckBox Content="{DynamicResource LangKeyAddHashtagsEvenIfThePostAlreadyHasHashtags}"
                          VerticalAlignment="Center" Margin="30,0"
                          IsChecked="{Binding TumblrModel.IsAddHashTagEvenIfAlreadyHastags}"
                          Visibility="{Binding TumblrModel.IsEnableDynamicHashTags,Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <StackPanel  Visibility="{Binding TumblrModel.IsAddHashTagEvenIfAlreadyHastags,
                     Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource LangKeyMaxHashtagsPerPost}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0"
                                                Value="{Binding TumblrModel.MaxHashtagsPerPostRange.StartValue}"/>
                        <TextBlock Text="-" VerticalAlignment="Center"/>
                        <controls:NumericUpDown Margin="5"
                                                Minimum="{Binding TumblrModel.MaxHashtagsPerPostRange.StartValue}"
                                                Value="{Binding TumblrModel.MaxHashtagsPerPostRange.EndValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource LangKeyPick}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0"
                                                Value="{Binding TumblrModel.PickPercentHashTag}"/>
                        <TextBlock Text="{DynamicResource LangKeyPercentOfTheExtraHashtagsFromThisList}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="50,0">
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource LangKeyPick}"/>
                        <controls:NumericUpDown Margin="5" Minimum="0"
                                                Value="{Binding TumblrModel.PickPercentFromList}"/>
                        <TextBlock Text="{DynamicResource LangKeyPercentFromThisList}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>    
    </StackPanel>
</UserControl>
