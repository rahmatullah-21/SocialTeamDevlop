<UserControl x:Class="DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings.PostLinkedInSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <StackPanel>
            <TextBlock Text="{DynamicResource DHlangLinkedPostType}" Margin="2"/>
            <RadioButton GroupName="LinkedinPostType" Content="{DynamicResource DHlangLinkedInGeneralPost}" Height="25" Margin="10 2"></RadioButton>
            <RadioButton GroupName="LinkedinPostType" Content="{DynamicResource DHlangLinkedInJobPost}" Height="25" Margin="10 2"></RadioButton>
            <RadioButton GroupName="LinkedinPostType" Content="{DynamicResource DHlangLinkedInAnnouncementPost}" Height="25" Margin="10 2"></RadioButton>
        </StackPanel>    
        
    </Grid>
</UserControl>
