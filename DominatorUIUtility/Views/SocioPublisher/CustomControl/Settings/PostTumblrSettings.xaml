<UserControl x:Class="DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings.PostTumblrSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" >
    <Grid>
        <StackPanel Orientation="Vertical">
            <CheckBox Margin="2" Content="{DynamicResource DHlangPostTagUser}" />
            <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="{DynamicResource DHlangAddPostTagUser}" Margin="2" TextWrapping="Wrap" Height="60" Width="404"></TextBox>
        </StackPanel>
    </Grid>
</UserControl>
