<UserControl x:Class="DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings.PostPinterestSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <StackPanel Orientation="Vertical">
            <CheckBox Name="CheckBoxPdSourceUrl" Margin="2" Content="{DynamicResource DHlangPdSourceUrl}" />
            <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Name="TextBoxPinterestSource" Text="Pinterest Source Url" Margin="2" TextWrapping="Wrap" Height="40" Width="250"></TextBox>
        </StackPanel>
    </Grid>
</UserControl>
