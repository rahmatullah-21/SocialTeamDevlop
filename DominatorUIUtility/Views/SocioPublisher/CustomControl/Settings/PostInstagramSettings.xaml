<UserControl x:Class="DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings.PostInstagramSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.SocioPublisher.CustomControl.Settings"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
            >
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Vertical" Margin="2" >
                <CheckBox Name="CheckBoxTitleForInstagram" Margin="2" Content="{DynamicResource DHlangPublisherInstagramTitle}" />
                <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Name="TextBoxTitle" mah:TextBoxHelper.Watermark="TitleDescription" Margin="2" TextWrapping="Wrap" Height="40" Width="404"></TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox Name="CheckBoxPostasPartStory" Margin="2" Content="{DynamicResource DHlangGdPostasStory}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox Name="CheckBoxDeletePost" Margin="2" Content="{DynamicResource DHlangGdDeletePost}" />
                <TextBox Width="40" Height="25" Margin="2"/>
                <TextBlock Text="{DynamicResource DHlangHours}" VerticalAlignment="Center" Margin="5"/>
            </StackPanel>
         
            <StackPanel Orientation="Vertical">
                <CheckBox Name="CheckBoxGeoLocation" Margin="2" Content="{DynamicResource DHlangGdPostUsignGeoLocation}" />
                <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Name="TextBoxGeoLocation" mah:TextBoxHelper.Watermark="{DynamicResource DHlangGdPostUsingAddGeoLocation}" Margin="2" TextWrapping="Wrap" Height="60" Width="404"></TextBox>
            </StackPanel>
            
            <StackPanel Orientation="Vertical">
                <CheckBox Margin="2" Content="{DynamicResource DHlangPostTagUser}" />
                <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" mah:TextBoxHelper.Watermark="{DynamicResource DHlangAddPostTagUser}" Margin="2" TextWrapping="Wrap" Height="60" Width="404"></TextBox>
            </StackPanel>
            
        </StackPanel>
        
        

    </Grid>
</UserControl>
