<UserControl x:Class="DominatorUIUtility.Views.Startup.JobConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.Views.Startup"
             mc:Ignorable="d" 
              xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Name="JobConfigGrid">
        <customControl:JobConfigControl JobConfiguration="{Binding JobConfiguration}"/>
    </Grid>
</UserControl>
