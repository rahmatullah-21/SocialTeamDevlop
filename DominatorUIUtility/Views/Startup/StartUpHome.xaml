<UserControl x:Class="DominatorUIUtility.Views.Startup.StartUpHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d"  x:Name="StartupUi"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">

    <Grid>
        <Grid.Resources>
            <Style TargetType="mah:Tile" x:Key="TileStyle">
                <Setter Property="Width" Value="100"/>
                <Setter Property="Height" Value="100"/>
                <Setter Property="HorizontalTitleAlignment" Value="Center"/>
                <Setter Property="VerticalTitleAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>
        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
            <mah:Tile Title="Beginner" Style="{StaticResource TileStyle}" Command="{Binding BeginnerCommand}"/>
            <mah:Tile Title="Pro"  Style="{StaticResource TileStyle}"/>
            <mah:Tile  Title="Advanced"  Style="{StaticResource TileStyle}"/>
        </WrapPanel>

    </Grid>
</UserControl>
