<UserControl x:Class="DominatorUIUtility.Views.Startup.SelectNetwork"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"  x:Name="StartupUi"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib" >

    <ListBox ItemsSource="{Binding LstNetwork}" SelectedItem="{Binding SelectedNetwork,Mode=TwoWay}"
             ItemContainerStyle="{StaticResource TransparentSelectedListBoxItem}">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid  Columns="4" Rows="3" />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Label Content="{Binding}" Foreground="White" FontWeight="Bold"
                           HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                           Background="{DynamicResource AccentBaseColorBrush}" Width="100" Height="100"/>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

</UserControl>
