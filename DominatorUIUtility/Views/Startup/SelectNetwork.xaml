<UserControl x:Class="DominatorUIUtility.Views.Startup.SelectNetwork"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"  x:Name="StartupUi"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:enum="clr-namespace:DominatorHouseCore.Enums;assembly=DominatorHouseCore">
    
    <ListBox ItemsSource="{Binding LstNetwork}" SelectedItem="{Binding SelectedNetwork}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <mah:Tile Title="{Binding}" Width="100" Height="100"
                                  HorizontalTitleAlignment="Center" VerticalAlignment="Center"/>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

</UserControl>
