            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <DockPanel>
                        <Border x:Name="bg" BorderBrush="{DynamicResource GreenColorAccordingTheme}" BorderThickness="1" CornerRadius="1" Width="15" Height="15" Background="Transparent"
                                    DockPanel.Dock="Left">
                            <Path x:Name="CheckMark"
                                          Width="8"
                                          Height="8"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 8 8 M 0 8 L 8 0"
                                          Stretch="Fill"
                                          Stroke="{DynamicResource GreenColorAccordingTheme}"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeThickness="1" />
                        </Border>

                        <ContentPresenter Margin="4,0,0,0"
                                              VerticalAlignment="Center" RecognizesAccessKey="False" />

                    </DockPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="false">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--    Below Design are specific for Template for the Crucials -->


    <Style x:Key="CrucialToggleButton" TargetType="{x:Type controls:ToggleSwitchButton}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border CornerRadius="12" BorderBrush="LightGray" Background="#FFEFF3F6" BorderThickness="1">
                        <Grid>
                            <Ellipse Width="16" Name="IsCheckedBackgroundRect"
                                                    Height="16"
                                                    Fill="SlateGray" Margin="-30,0,0,0"/>
                            <TextBlock Margin="7,0,0,0" Opacity="0" DockPanel.Dock="Left"  HorizontalAlignment="Left" Text="On" Name="OnText" Foreground="DarkSlateGray" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock HorizontalAlignment="Right" Text="Off" Name="OffText" Foreground="DarkSlateGray" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,9,0" />
                        </Grid>

                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsChecked , RelativeSource={RelativeSource Self}}" Value="true">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Name="enterBoard">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                            <SplineThicknessKeyFrame KeyTime="00:00:00" Value="-30, 0,0,0" />
                                            <SplineThicknessKeyFrame KeyTime="00:00:00.10" Value="30, 0,0,0" />
                                        </ThicknessAnimationUsingKeyFrames>
                                        <ColorAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)">
                                            <LinearColorKeyFrame KeyTime="0:0:0.10" Value="#FF35C77B"/>
                                        </ColorAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="OffText" Storyboard.TargetProperty="Opacity" To="0" Duration="00:00:00.03"/>
                                        <DoubleAnimation Storyboard.TargetName="OnText" Storyboard.TargetProperty="Opacity" To="1" Duration="00:00:00.03"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard Name="exitBoard">
                                    <Storyboard>
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                            <SplineThicknessKeyFrame KeyTime="00:00:00:00" Value="30, 0,0,0" />

                                            <SplineThicknessKeyFrame KeyTime="00:00:00.10" Value="-30, 0,0,0" />
                                        </ThicknessAnimationUsingKeyFrames>
                                        <ColorAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)">
                                            <LinearColorKeyFrame KeyTime="0:0:0.10" Value="#FFA4ADB7"/>
                                        </ColorAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="OffText" Storyboard.TargetProperty="Opacity" To="1" Duration="00:00:00.03"/>
                                        <DoubleAnimation Storyboard.TargetName="OnText" Storyboard.TargetProperty="Opacity" To="0" Duration="00:00:00.03"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CrucialToggleButtonWithStatus" TargetType="{x:Type controls:ToggleSwitchButton}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border BorderBrush="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="12" MinHeight="22" MinWidth="50" BorderBrush="LightGray" Background="#FFEFF3F6" BorderThickness="1">
                                <Grid>
                                    <Ellipse Width="16" Name="IsCheckedBackgroundRect"
                                                    Height="16"
                                                    Fill="#FFA4ADB7" Margin="-30,0,0,0"/>
                                    <TextBlock Margin="7,0,0,0" Opacity="0" DockPanel.Dock="Left"  HorizontalAlignment="Left" Text="On" Name="OnText" Foreground="#FF71777C" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock HorizontalAlignment="Right" Text="Off" Name="OffText" Foreground="#FF71777C" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,7,0" />
                                </Grid>
                            </Border>
                            <TextBlock Name="StatusText" Margin="5,0" FontWeight="SemiBold" VerticalAlignment="Center" Text="Paused" Foreground="#FF71777C" FontSize="15"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsChecked , RelativeSource={RelativeSource Self}}" Value="true">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Name="enterBoard">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                            <SplineThicknessKeyFrame KeyTime="00:00:00" Value="-30, 0,0,0" />
                                            <SplineThicknessKeyFrame KeyTime="00:00:00.10" Value="30, 0,0,0" />
                                        </ThicknessAnimationUsingKeyFrames>
                                        <ColorAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)">
                                            <LinearColorKeyFrame KeyTime="0:0:0.10" Value="#FF35C77B"/>
                                        </ColorAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="OffText" Storyboard.TargetProperty="Opacity" To="0" Duration="00:00:00.03"/>
                                        <DoubleAnimation Storyboard.TargetName="OnText" Storyboard.TargetProperty="Opacity" To="1" Duration="00:00:00.03"/>
                                        <StringAnimationUsingKeyFrames 
                                                Storyboard.TargetName="StatusText" Storyboard.TargetProperty="(TextBlock.Text)">
                                            <DiscreteStringKeyFrame Value="Active" KeyTime="00:00:00.10" />
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard Name="exitBoard">
                                    <Storyboard>
                                        <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                            <SplineThicknessKeyFrame KeyTime="00:00:00:00" Value="30, 0,0,0" />

                                            <SplineThicknessKeyFrame KeyTime="00:00:00.10" Value="-30, 0,0,0" />
                                        </ThicknessAnimationUsingKeyFrames>
                                        <ColorAnimationUsingKeyFrames Storyboard.TargetName="IsCheckedBackgroundRect"
                                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)">
                                            <LinearColorKeyFrame KeyTime="0:0:0.10" Value="#FFA4ADB7"/>
                                        </ColorAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="OffText" Storyboard.TargetProperty="Opacity" To="1" Duration="00:00:00.03"/>
                                        <DoubleAnimation Storyboard.TargetName="OnText" Storyboard.TargetProperty="Opacity" To="0" Duration="00:00:00.03"/>
                                        <StringAnimationUsingKeyFrames 
                                                Storyboard.TargetName="StatusText" Storyboard.TargetProperty="(TextBlock.Text)">
                                            <DiscreteStringKeyFrame Value="Paused" KeyTime="00:00:00.10" />
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GridViewColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource MetroGridViewColumnHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
        <Setter Property="FontWeight" Value="SemiBold"></Setter>
    </Style>

    <Style x:Key="GridSplitterStyle1" TargetType="{x:Type GridSplitter}">
        <Setter Property="Background"
          Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
        <Setter Property="PreviewStyle">
            <Setter.Value>
                <Style>
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Rectangle Fill="#80000000"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="2"/>
                        </Grid.RowDefinitions>
                        <Border Visibility="Visible" Background="{TemplateBinding Background}" Height="30" Width="15" Margin="0,0,2,0" HorizontalAlignment="Right" Padding="0,4,0,0" CornerRadius="5,5,0,0" >

                        </Border>
                        <Rectangle Grid.Row="0" Height="27" Width="25" VerticalAlignment="Center" Margin="0,3,-3,0" HorizontalAlignment="Right">
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/DominatorUIUtility;component/Images/ArrowIcon.png" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Border Grid.Row="1" Background="{TemplateBinding Background}" Height="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                VerticalAlignment="Top"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
