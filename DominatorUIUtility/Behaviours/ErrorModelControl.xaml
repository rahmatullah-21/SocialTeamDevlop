<UserControl x:Class="DominatorUIUtility.Behaviours.ErrorModelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" MaxWidth="500">
    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" Margin="10" BorderBrush="{DynamicResource AccentColorBrush3}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Accounts,IsAsync=True}" 
                      AutoGenerateColumns="False" EnableRowVirtualization="True" 
                      CanUserAddRows="False" Foreground="White" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      GridLinesVisibility="All" 
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.IsDeferredScrollingEnabled="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*">
                        <DataGridTemplateColumn.Header>
                            <CheckBox Content="{DynamicResource LangKeySelectAll}"
                                      IsChecked="{Binding DataContext.IsAllAccountSelected, 
                                      RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                          Margin="5,0,0,0" Content="{Binding UserName}" Click="AccountChecked"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
        <StackPanel Grid.Row="1">
            <TextBlock Margin="10" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" TextWrapping="WrapWithOverflow"
                       Text="{Binding WarningText}"/>
            <TextBlock HorizontalAlignment="Right" Margin="0,5,10,5" FontWeight="SemiBold" FontSize="17" Text="{DynamicResource LangKeyWouldYouStillLikeToProceed}"/>
        </StackPanel>

        <StackPanel Margin="0,10,0,10" Orientation="Horizontal"  Grid.Row="2" HorizontalAlignment="Right">
            <Button Name="BtnSave" Click="BtnSave_OnClick" Background="{DynamicResource AccentBaseColorBrush}" 
                Foreground="White" HorizontalAlignment="Right" Margin="0,0,5,10" x:FieldModifier="public">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="15" Height="15" Fill="White">
                            <Rectangle.OpacityMask>
                                <VisualBrush Visual="{StaticResource appbar_save}" Stretch="Fill"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="{DynamicResource LangKeySave}" Margin="6,0"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Name="BtnCancel" Click="BtnCancel_OnClick"  Background="{DynamicResource AccentBaseColorBrush}" x:FieldModifier="public" Foreground="White" HorizontalAlignment="Right" Margin="0,0,5,10">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="15" Height="15" Fill="White">
                            <Rectangle.OpacityMask>
                                <VisualBrush Visual="{StaticResource appbar_cancel}" Stretch="Fill"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="{DynamicResource LangKeyCancel}" Margin="6,0"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
