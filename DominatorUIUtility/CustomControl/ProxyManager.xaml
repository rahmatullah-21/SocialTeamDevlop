<UserControl x:Class="DominatorUIUtility.CustomControl.ProxyManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl" Name="proxyManager" 
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls" Loaded="ProxyManager_OnLoaded"
             xmlns:converter="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:enums="clr-namespace:DominatorHouseCore.Enums;assembly=DominatorHouseCore"
             xmlns:validation="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore">

    <UserControl.Resources>

        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:IndexToRowNoConverter x:Key="IndexToRowNoConverter"/>
        <!--<converter:BooleanToWidthConverter x:Key="BooleanToWidthConverter"/>-->
        <converter:ProxyPortToIpAddressConvertor x:Key="ProxyPortToIpAddressConvertor"/>
        <converter:ListConvertor x:Key="ListConvertor"/>
        <converter:AlternationIndexConverter x:Key="AlternationIndexConverter"/>
        <DataTemplate x:Key="AccountsAssignedToTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ContentControl Margin="10,0" VerticalAlignment="Center" >
                        <ContentControl.Style>
                            <Style TargetType="{x:Type ContentControl}"  >
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Facebook}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="#003569" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_social_facebook_variant}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Instagram}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="Red" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource Instagram}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Twitter}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="#3897F0" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_twitter_bird}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Pinterest}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="Red" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_social_pinterest}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Quora}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="Red" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource Quora}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Reddit}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="OrangeRed" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_social_reddit}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.LinkedIn}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="DodgerBlue" Width="20" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_social_linkedin_variant}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Tumblr}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="DimGray" Width="16" Height="20">
                                                    <Rectangle.Resources>
                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                    </Rectangle.Resources>
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_social_tumblr}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Gplus}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_googleplus}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Youtube}">
                                        <Setter Property="Content" >
                                            <Setter.Value>
                                                <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush Visual="{StaticResource appbar_youtube}" Stretch="Fill" />
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>


                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                    <TextBlock Text="{Binding UserName}" VerticalAlignment="Center" x:Name="txtblkaccount"/>
                </StackPanel>
                <Button Content="{DynamicResource langRemove}" x:Name="btnRemoveAccountFromProxy"  Grid.Column="1"
                        HorizontalAlignment="Left"  FontWeight="SemiBold" VerticalAlignment="Center" 
                        Foreground="{Binding ElementName=txtblkaccount,Path=Foreground}"
                        Background="Transparent" Click="btnRemoveAccountFromProxy_Click"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AccountsToBeAssignTemplate">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="Account" Checked="Account_Checked"/>
                <ContentControl Margin="10,0" VerticalAlignment="Center">
                    <ContentControl.Style>
                        <Style TargetType="{x:Type ContentControl}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Facebook}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="#003569" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_social_facebook_variant}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Instagram}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="Red" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource Instagram}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Twitter}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="#3897F0" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_twitter_bird}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Pinterest}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="Red" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_social_pinterest}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Quora}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="Red" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource Quora}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Reddit}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="OrangeRed" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_social_reddit}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.LinkedIn}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="DodgerBlue" Width="20" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_social_linkedin_variant}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Tumblr}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="DimGray" Width="16" Height="20">
                                                <Rectangle.Resources>
                                                    <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                </Rectangle.Resources>
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_social_tumblr}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Gplus}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_googleplus}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=AccountNetwork}" Value="{x:Static enums:SocialNetworks.Youtube}">
                                    <Setter Property="Content" >
                                        <Setter.Value>
                                            <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush Visual="{StaticResource appbar_youtube}" Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
                <TextBlock Text="{Binding UserName}" VerticalAlignment="Center" x:Name="txtblkaccount"/>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <Grid.RowDefinitions>
            <RowDefinition Height="4*" />
            <RowDefinition Height="10*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">

                <Button Height="30"   x:Name="btnImportProxies" Margin="10,5" Command="{Binding ImportProxyCommand}"
                Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" ToolTip="{DynamicResource DHImportProxyDescription}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle  Width="16" Height="15" Fill="White" VerticalAlignment="Center">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_inbox_in}"></VisualBrush>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langImportProxies}" Margin="5,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button  Height="30"  x:Name="btnExportProxies" Margin="10,5" Command="{Binding ExportProxyCommand}"
                Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" >
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle  Width="16" Height="15" Fill="White" VerticalAlignment="Center">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_inbox_out}"></VisualBrush>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langExportProxies}" Margin="5,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button  Height="30"  x:Name="btnAddProxy" Margin="10,5"
                Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" Command="{Binding AddProxyCommand}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle  Width="16" Height="15" Fill="White" VerticalAlignment="Center">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_add}"></VisualBrush>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langAddProxy}" Margin="5,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

            </StackPanel>

            <StackPanel Orientation="Horizontal"  Margin="5">

                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.IsHideAssignedSocialProfiles}"
                          Name="ChkHideUnhideSocialProfiles"
                          Command="{Binding HideUnhideSocialProfilesCommand}"
                         
                          Content="{DynamicResource langHideAssignedSocialProfiles}">
                    <CheckBox.CommandParameter>
                        <MultiBinding Converter="{StaticResource ListConvertor}" UpdateSourceTrigger="PropertyChanged">
                            <Binding ElementName="ProxyDataGrid" />
                            <Binding Path="ProxyManagerModel.IsHideAssignedSocialProfiles" />
                        </MultiBinding>
                    </CheckBox.CommandParameter>
                </CheckBox>
                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.IsHideUsernameAndPassword}" 
                          Content="{DynamicResource langHideUsernameAndPassword}"
                          Command="{Binding HideUnhideUserPasswordCommand}">
                    <CheckBox.CommandParameter>
                        <MultiBinding Converter="{StaticResource ListConvertor}" UpdateSourceTrigger="PropertyChanged">
                            <Binding ElementName="ProxyDataGrid" />
                            <Binding Path="ProxyManagerModel.IsHideUsernameAndPassword" />
                        </MultiBinding>
                    </CheckBox.CommandParameter>
                </CheckBox>
                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.IsShowByGroup}" 
                          Content="{DynamicResource DHlangShowByGroup}"
                          x:Name="ShowByGroup" Command="{Binding ShowByGroupCommand}"
                          CommandParameter="{Binding ProxyManagerModel.IsShowByGroup}"/>
                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.FilterByGroup}"
                          Content="{DynamicResource langFilterByGroup}" x:Name="FilterByGroup"/>
                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.IsShowProxiesWithError}" 
                          Content="{DynamicResource langShowProxiesWithError}" Name="ShowProxiesWithError"
                         Command="{Binding ShowProxiesWithErrorCommand}"
                          CommandParameter="{Binding ProxyManagerModel.IsShowProxiesWithError}"/>
                <CheckBox Margin="5" IsChecked="{Binding ProxyManagerModel.IsShowUnassignedProxies}"
                          Content="{DynamicResource langShowUnassignedProxies}" 
                          x:Name="chkShowUnassignedProxies" 
                          Command="{Binding ShowUnassignedProxiesCommand}"
                          CommandParameter="{Binding ProxyManagerModel.IsShowUnassignedProxies}"/>

            </StackPanel>

            <StackPanel  Orientation="Horizontal" Margin="5">
                <TextBlock VerticalAlignment="Center" Margin="5" Text="{DynamicResource langFilter}"/>
                <TextBox Width="200" Height="25" Name="txtfilter" Text="{Binding ProxyManagerModel.Filter}" TextChanged="txtfilter_TextChanged"/>
                <TextBlock VerticalAlignment="Center" Margin="20,5" Text="{DynamicResource langURLToUseToVerifyProxies}"/>
                <TextBox Width="200" Height="25" Name="txtURLToUseToVerifyProxies" Text="{Binding ProxyManagerModel.URLToUseToVerifyProxies}"/>
                <StackPanel Orientation="Horizontal" x:Name="cmbFilterBytag" Margin="30,0"
                            Visibility="{Binding ProxyManagerModel.FilterByGroup,Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock VerticalAlignment="Center" Margin="20,5" Text="{DynamicResource langSelectTag}"/>
                    <ComboBox  Width="200" ItemsSource="{Binding ProxyManagerModel.Groups}" Name="Group" SelectionChanged="Group_SelectionChanged"/>
                </StackPanel>
            </StackPanel>

            <StackPanel  Orientation="Horizontal" >

                <Button  Height="30"  x:Name="btnDeleteSelected" Margin="10,5"
                Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" Click="btnDeleteSelected_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle  Width="15" Height="18" Fill="White">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Visual="{StaticResource appbar_delete}" Stretch="Fill"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langDeleteSelected}" Margin="5,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button  Height="30"  x:Name="btnExportSelected" Margin="10,5" Click="btnExportSelected_Click"
                Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" >
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle  Width="16" Height="15" Fill="White" VerticalAlignment="Center">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_inbox_out}"></VisualBrush>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langExportSelected}" Margin="5,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

            </StackPanel>

        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding ProxyManagerCollection}"
                           AutoGenerateColumns="False"
                           CanUserAddRows="False" Foreground="White" 
                           AlternationCount="{Binding Items.Count, RelativeSource={RelativeSource Self}}"
                           ScrollViewer.HorizontalScrollBarVisibility="Auto"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           GridLinesVisibility="All"
                  x:Name="ProxyDataGrid">
            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGridCell}">
                    <Setter Property="Foreground" Value="{DynamicResource MetroDataGrid.InactiveSelectionHighlightBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>

                        </Trigger>

                    </Style.Triggers>
                </Style>
              <ControlTemplate x:Key="ErrorTemplate">
                    <StackPanel Orientation="Vertical">
                        <AdornedElementPlaceholder x:Name="ErrorHolder" >
                            <Border BorderBrush="red" BorderThickness="1" >
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text,ElementName=error}" Value="Invalid proxy address" >
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </AdornedElementPlaceholder>
                        <TextBlock  VerticalAlignment="Center" Name="error"  FontWeight="SemiBold"  Text="{Binding ElementName=ErrorHolder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" Foreground="Red">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text,ElementName=error}" Value="Invalid proxy address" >
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>

                        </TextBlock>
                    </StackPanel>
                </ControlTemplate>
            </DataGrid.Resources>
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Margin" Value="0,0,0,5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander Margin="5" Header="{Binding Path=Name}">
                                            <Expander.Content>
                                                <ItemsPresenter/>
                                            </Expander.Content>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.Header>
                        <CheckBox Name="AllProxyChecked" Content=" #"
                                      IsChecked="{Binding IsAllProxySelected}"
                                      Checked="AllProxyChecked_Checked" 
                                      Unchecked="AllProxyChecked_Unchecked"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding ProxyManagerModel.IsProxySelected}"
                                          Margin="5,0,0,0" Content="{Binding AlternationIndex, 
                                        RelativeSource={RelativeSource AncestorType=DataGridRow},
                                        Converter={StaticResource AlternationIndexConverter}}"/>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource langName}" Binding="{Binding AccountProxy.ProxyName}"/>
                <DataGridTemplateColumn Header="{DynamicResource langProxyIpPort}">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Width="120"  Validation.ErrorTemplate="{StaticResource ErrorTemplate}">
                                <TextBox.Text>
                                    <MultiBinding Converter="{StaticResource ProxyPortToIpAddressConvertor}" UpdateSourceTrigger="PropertyChanged">
                                        <MultiBinding.ValidationRules>
                                            <validation:IPAddressValidation ValidationStep="RawProposedValue" />
                                        </MultiBinding.ValidationRules>
                                        <Binding Path="AccountProxy.ProxyIp" />
                                        <Binding Path="AccountProxy.ProxyPort" />
                                    </MultiBinding>
                                </TextBox.Text>
                            </TextBox>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource langProxyUsername}" Binding="{Binding AccountProxy.ProxyUsername}"/>
                <DataGridTextColumn Header="{DynamicResource langProxyPassword}" Binding="{Binding AccountProxy.ProxyPassword}"/>
                <DataGridTemplateColumn Header="{DynamicResource langSocialProfiles}">
                    
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Controls:DropDownButton x:Name="dropdown" Width="40" Height="20"
                                                             ItemTemplate="{StaticResource AccountsAssignedToTemplate}" 
                                                             ItemsSource="{Binding AccountsAssignedto}" 
                                                             Content="{Binding Path=AccountsAssignedto.Count}"
                                                             Click="dropdown_Click" >
                                    <Controls:DropDownButton.Style>
                                        <Style TargetType="{x:Type Controls:DropDownButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=AccountsAssignedto.Count}" Value="0">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Controls:DropDownButton.Style>

                                </Controls:DropDownButton>

                                <Controls:DropDownButton x:Name="AddDropdown" Width="40" Height="20" Margin="10,0"
                                                             ItemTemplate="{StaticResource AccountsToBeAssignTemplate}" 
                                                             ItemsSource="{Binding AccountsToBeAssign}" 
                                                             Content="{DynamicResource langAdd}"
                                                             Click="dropdown_Click" >
                                    <Controls:DropDownButton.Style>
                                        <Style TargetType="{x:Type Controls:DropDownButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=AccountsToBeAssign.Count}" Value="0">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Controls:DropDownButton.Style>
                                </Controls:DropDownButton>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource langStatus}" 
                                            Binding="{Binding Status}" IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource langResponseTime}"
                                            Binding="{Binding ResponseTime}" IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource langFailures}"
                                            Binding="{Binding Failures}" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="{DynamicResource langAction}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource langUpdateProxy}" x:Name="btnUpdateProxy" 
                                                FontWeight="SemiBold" Click="BtnUpdateProxy_OnClick"
                                                Foreground="{DynamicResource AccentBaseColorBrush}" Background="Transparent" />
                                <Button Content="{DynamicResource langDelete}" x:Name="btnDeletesProxy" 
                                                FontWeight="SemiBold" Click="btnDeletesProxy_Click"
                                                Foreground="{DynamicResource AccentBaseColorBrush}" Background="Transparent" />
                                <Button Content="{DynamicResource langVerifyProxy}"  x:Name="btnVerifyProxy" 
                                                FontWeight="SemiBold" Click="btnVerifyProxy_Click"
                                                Foreground="{DynamicResource AccentBaseColorBrush}" Background="Transparent"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource langGroup}"
                                            Binding="{Binding AccountProxy.ProxyGroup}" IsReadOnly="True"/>


            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</UserControl>
