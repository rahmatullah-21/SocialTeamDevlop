<UserControl x:Class="DominatorUIUtility.CustomControl.InputBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             mc:Ignorable="d" xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
            >
    <Grid x:Name="MainGrid">
        <StackPanel Orientation="Horizontal"  >
            <TextBox  TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding InputText}" Controls:TextBoxHelper.Watermark="{Binding WaterMarkText}"
                              Name="TxtInvalidWord"  VerticalScrollBarVisibility="Auto" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="300" Height="{Binding Height}"  BorderBrush="{DynamicResource AccentBaseColorBrush}" BorderThickness="2"/>
            <StackPanel VerticalAlignment="Center">
                <Button Name="BtnImportBlacklistsText" Visibility="{Binding ImportVisiblity}" Foreground="White"  Background="{DynamicResource AccentBaseColorBrush}" Click="BtnImportBlacklistsText_OnClick"
                                HorizontalAlignment="Right"  Height="25" Width="35" VerticalAlignment="Center" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" ToolTip="{DynamicResource LangKeyImportFromCsvTxt}">

                        <Rectangle Width="13" Height="15" Fill="White"  HorizontalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_page_upload}" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </StackPanel>
                </Button>
                <Button Name="BtnRefereshBlacklistsText" Visibility="{Binding RefreshVisiblity}" Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" HorizontalAlignment="Right"  Height="25" Width="35" VerticalAlignment="Center"  Click="BtnRefereshBlacklistsText_OnClick" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" ToolTip="Clear﻿﻿﻿﻿ All">
                        <Rectangle Width="13" Height="15" Fill="White"  HorizontalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_clean}" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </StackPanel>
                </Button>
                <Button Name="BtnSaveBlacklistsText"  Foreground="White"  Visibility="{Binding SaveVisiblity}" Background="{DynamicResource AccentBaseColorBrush}" HorizontalAlignment="Right" 
                        Height="25" Width="35" VerticalAlignment="Center"  Command="{Binding SaveCommand}" CommandParameter="{Binding CommandParameter}" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" ToolTip="{DynamicResource LangKeySave}">
                        <Rectangle Width="13" Height="15" Fill="White"  HorizontalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_save}" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=Text,ElementName=TxtInvalidWord}" Value="">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
