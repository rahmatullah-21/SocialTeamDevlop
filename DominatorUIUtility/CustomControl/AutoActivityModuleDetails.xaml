<UserControl x:Class="DominatorUIUtility.CustomControl.AutoActivityModuleDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" Name="ModuleDetails">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <TextBlock Foreground="{DynamicResource AccentBaseColorBrush}" Text="{Binding ActivityDetailsModel.Title}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="5" />
            <controls:ToggleSwitch OnLabel="" OffLabel=""  Margin="6,0,0,0" HorizontalAlignment="Center" IsCheckedChanged="ActivityChanged_OnIsCheckedChanged" VerticalAlignment="Center" Tag="{Binding ActivityDetailsModel.Status}" >
                <controls:ToggleSwitch.Style>
                    <Style TargetType="controls:ToggleSwitch" BasedOn="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                        <Style.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="IsChecked" Value="True" />
                            </Trigger>
                            <Trigger Property="Tag" Value="InActive">
                                <Setter Property="IsChecked" Value="False" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </controls:ToggleSwitch.Style>
            </controls:ToggleSwitch>
        </StackPanel>
    </Grid>
</UserControl>
