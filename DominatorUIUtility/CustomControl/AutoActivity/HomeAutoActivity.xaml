<UserControl x:Class="DominatorUIUtility.CustomControl.AutoActivity.HomeAutoActivity"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl.AutoActivity"
             xmlns:viewModel="clr-namespace:DominatorHouseCore.ViewModel.AutoActivity;assembly=DominatorHouseCore"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModel:SocialAutoActivityViewModel}">
            <local:SocialAutoActivity />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:DominatorAutoActivityViewModel}">
            <local:DominatorAutoActivity />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <ContentControl Content="{Binding UserControlSwitchViewModel}" />
    </Grid>
</UserControl>
