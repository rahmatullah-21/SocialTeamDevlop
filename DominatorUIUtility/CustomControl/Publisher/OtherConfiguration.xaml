<UserControl x:Class="DominatorUIUtility.CustomControl.Publisher.OtherConfiguration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl.Publisher"
             mc:Ignorable="d" 
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel x:Name="MainGrid">
        <Label Content="{DynamicResource langSettings}" Margin="5" FontWeight="Bold"/>
        <StackPanel>
            <!--<Label Content="{DynamicResource langCampaignsTags}"/>
            <ComboBox Text="{Binding OtherConfigurations.CampaignTag}"
                      x:Name="cmbCampaignTags" IsEditable="True" Width="400"
                      HorizontalAlignment="Left" Margin="5"/>-->
            <CheckBox IsChecked="{Binding OtherConfigurations.IsEnableSignatureChecked}"
                      Content="{DynamicResource langEnableSignature}"  Margin="5"/>
            <TextBox Text="{Binding OtherConfigurations.SignatureText}" Width="330" HorizontalAlignment="Left"
                     Margin="30,5" Visibility="{Binding OtherConfigurations.IsEnableSignatureChecked,
                     Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <CheckBox IsChecked="{Binding OtherConfigurations.IsShortenURLsChecked}"
                      Content="{DynamicResource langShortenURLs}"  Margin="5"/>
            <!--<CheckBox IsChecked="{Binding OtherConfigurations.IsPostTextChecked}" 
                      Content="{DynamicResource langPostText}"  Margin="5"/>-->
            <CheckBox IsChecked="{Binding OtherConfigurations.IsAllowPublishingPinterestChecked}"
                      Content="{DynamicResource langAllowPublishingPinterest}"  Margin="5"/>
            <CheckBox IsChecked="{Binding OtherConfigurations.IsPostAsStoryChecked}"
                      Content="{DynamicResource langPostAsStory}"  Margin="5"/>
            <!--<StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding OtherConfigurations.IsMakeImagesUniqueChecked}"
                          Content="{DynamicResource langMakeImagesUnique}"  Margin="5"/>
                <ComboBox x:Name="cmbMakeImagesUnique" Width="80" ItemsSource="{Binding OtherConfigurations.MakeImagesUniqueStatus}"/>
                <Label Content="{DynamicResource langImageChanges}"/>
            </StackPanel>
            <CheckBox IsChecked="{Binding OtherConfigurations.IsEnableWatermarkChecked}" 
                      Content="{DynamicResource langEnableWatermark}"  Margin="5"/>
            <CheckBox Content="{DynamicResource langEnableCustomTokens}"
                      IsChecked="{Binding OtherConfigurations.IsEnableCustomTokensChecked}"  Margin="5"/>-->
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button Content="{DynamicResource langAdvancedSettings}"
                        x:Name="btnAdvancedSettings" Foreground="White" Background="{DynamicResource AccentBaseColorBrush}" 
                        Click="btnAdvancedSettings_Click"/>
                <!--<Button Content="{DynamicResource langCopySettings}" x:Name="btnCopySettings" Margin="10,0,0,0" Foreground="White" Background="{DynamicResource AccentBaseColorBrush}"/>-->
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
