<UserControl x:Class="DominatorUIUtility.CustomControl.Publisher.JobConfiguration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl.Publisher"
             xmlns:control="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:behaviours="clr-namespace:DominatorUIUtility.Behaviours"
             xmlns:validation="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <ControlTemplate x:Key="ErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="ErrorHolder" >
                    <Border BorderBrush="red" BorderThickness="1" />
                </AdornedElementPlaceholder>
                <TextBlock  VerticalAlignment="Center" FontWeight="Bold" Text="{Binding ElementName=ErrorHolder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" Foreground="Red"/>
            </StackPanel>
        </ControlTemplate>


    </UserControl.Resources>
    <StackPanel x:Name="MainGrid">

        <TextBlock Text="{DynamicResource langSettings}" FontWeight="Bold"  Margin="5"/>
        <StackPanel Orientation="Horizontal" Margin="10,0">
            <TextBlock Text="{DynamicResource langCampaignWillPublish}" VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown x:Name="numericMaxPost" Minimum="0"
                                   Value="{Binding JobConfigurations.MaxPost,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="5"                                   
                                   ValueDecremented="NumericMaxPost_OnValueDecremented"
                                   ValueIncremented="NumericMaxPost_OnValueIncremented"/>

            <TextBlock Text="{DynamicResource langPostListItemsPerDay}" VerticalAlignment="Center" Margin="5"/>

            <validation:ValidationBinding In="{Binding JobConfigurations.TimeRange.StartTime, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                           Out="{Binding ElementName=endtime, Path=Min,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" />
            <validation:ValidationBinding In="{Binding JobConfigurations.TimeRange.EndTime, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                          Out="{Binding ElementName=starttime, Path=Max,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" />

            <control:TimePicker Validation.ErrorTemplate="{StaticResource ErrorTemplate}" SelectedTimeChanged="OnSelectedTimeChanged" VerticalAlignment="Center" Margin="5" IsClockVisible="False" >
                <control:TimePicker.SelectedTime>
                    <Binding Path="JobConfigurations.TimeRange.StartTime" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validation:StartTimeValidator  x:Name="starttime" ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </control:TimePicker.SelectedTime >
            </control:TimePicker>
            <TextBlock Text="{DynamicResource langAnd}"  VerticalAlignment="Center" Margin="5"/>
            <control:TimePicker Validation.ErrorTemplate="{StaticResource ErrorTemplate}" SelectedTimeChanged="OnSelectedTimeChanged"
                                VerticalAlignment="Center" Margin="5" IsClockVisible="False">
                <control:TimePicker.SelectedTime>
                    <Binding Path="JobConfigurations.TimeRange.EndTime" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validation:EndTimeValidator  x:Name="endtime" ValidatesOnTargetUpdated="True"/>
                        </Binding.ValidationRules>
                    </Binding>
                </control:TimePicker.SelectedTime >
            </control:TimePicker>
            <TextBlock Text="{DynamicResource langPostListItemSentToGroupsPageWalls}"  VerticalAlignment="Center" Margin="5"/>
        </StackPanel>



        <RadioButton GroupName="postGroup" IsChecked="{Binding JobConfigurations.IsSpecifyPostingIntervalChecked}" Content="{DynamicResource langSpecifyPostingInterval}"  Margin="5"
                     Name="ChkPostingInterval" Checked="ChkPostingInterval_OnChecked"/>
        <ItemsControl ItemsSource="{Binding JobConfigurations.LstTimer}" Margin="5"
                      Visibility="{Binding JobConfigurations.IsSpecifyPostingIntervalChecked,
            Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" IsItemsHost="True" HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <StackPanel>
                            <control:TimePicker x:Name="StartTime" Margin="2"
                                                SelectedTime="{Binding StartTime
                                    ,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                                                IsClockVisible="False"/>
                            <control:TimePicker x:Name="EndTime" Margin="2"
                                                SelectedTime="{Binding EndTime
                                    ,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                                                IsClockVisible="False"/>
                        </StackPanel>
                        <control:TimePicker x:Name="MidTime" VerticalAlignment="Center" Margin="2"
                                            SelectedTime="{Binding MidTime
                                ,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" 
                                            IsClockVisible="False"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <RadioButton GroupName="postGroup" IsChecked="{Binding JobConfigurations.IsRandomizePublishingTimerChecked}" Content="{DynamicResource langRandomizePublishingTimer}"  Margin="5"
                     Name="ChkRandomizePublishing" Checked="ChkRandomizePublishing_OnChecked"/>
        <ItemsControl ItemsSource="{Binding JobConfigurations.LstTimer}" Margin="5"
                      Visibility="{Binding JobConfigurations.IsRandomizePublishingTimerChecked,
                 Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" IsItemsHost="True" HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <control:TimePicker x:Name="lstTime" 
                                            SelectedTime="{Binding MidTime
                        ,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" IsClockVisible="False"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <RadioButton  GroupName="postGroup" IsChecked="{Binding JobConfigurations.IsRandomizeNumberOfPostsChecked}" Content="{DynamicResource langRandomizeNumberOfPosts}"  Margin="5"/>
        <StackPanel Orientation="Horizontal"  Margin="30,5"
                    Visibility="{Binding JobConfigurations.IsRandomizeNumberOfPostsChecked,
                    Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource langPostBetween}" VerticalAlignment="Center"  Margin="5"/>
            <control:NumericUpDown Minimum="0"
                    Value="{Binding JobConfigurations.PostBetween.StartValue}"
                    VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langTo}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.PostBetween.StartValue}" Value="{Binding JobConfigurations.PostBetween.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource DHlangPostPerDay}"  VerticalAlignment="Center" Margin="5"/>
            <TextBlock Text="{DynamicResource DHlangIncreaseEachDay}"  VerticalAlignment="Center" Margin="0,5"/>
            <control:NumericUpDown Value="{Binding JobConfigurations.IncreaseEachDay.StartValue}"
                                   VerticalAlignment="Center"  Margin="5" Minimum="0"/>
            <TextBlock Text="{DynamicResource langUntilitReaches}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.IncreaseEachDay.StartValue}" 
                                   Value="{Binding JobConfigurations.IncreaseEachDay.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langMaxPostPerDay}"  VerticalAlignment="Center" Margin="5"/>

        </StackPanel>
        <CheckBox Content="{DynamicResource langPublishPostOnDestinations}" IsChecked="{Binding JobConfigurations.IsPublishPostOnDestinationsChecked}"  Margin="5" />


        <StackPanel Orientation="Horizontal" Margin="30,5" >
           <StackPanel.Style>
               <Style TargetType="StackPanel">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding JobConfigurations.IsPublishPostOnDestinationsChecked}" Value="False">
                            <Setter Property="Visibility" Value="Visible"></Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding JobConfigurations.IsPublishPostOnDestinationsChecked}" Value="True">
                            <Setter  Property="Visibility" Value="Collapsed"></Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{DynamicResource DHlangPublishOn}" VerticalAlignment="Center"  Margin="5"/>
            <control:NumericUpDown Minimum="0"
                     Value="{Binding JobConfigurations.PublishOn}"
                     VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource DHlangRandomDestinations}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.MaxDestination}" Value="{Binding JobConfigurations.PostBetween.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource DHlangDestFromEachAccount}"  VerticalAlignment="Center" Margin="5"/>
        </StackPanel>
        <CheckBox Content="{DynamicResource DHlangAddDelayBetweenPublishingPost}" IsChecked="{Binding JobConfigurations.IsAddDelayBetweenPublishingPost}"  Margin="5"/>
        <StackPanel Orientation="Horizontal"  Margin="30,5"
                    Visibility="{Binding JobConfigurations.IsAddDelayBetweenPublishingPost,
                    Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource DHlangDelayBetween}" VerticalAlignment="Center"  Margin="5"/>
            <control:NumericUpDown Minimum="0"
                     Value="{Binding JobConfigurations.DelayBetween.StartValue}"
                     VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langAnd}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.DelayBetween.StartValue}" 
                                   Value="{Binding JobConfigurations.DelayBetween.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource DHlangMinuteAfterPublishing}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="0"
                     Value="{Binding JobConfigurations.PostRange.StartValue}"
                     VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langTo}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.PostRange.EndValue}" Value="{Binding JobConfigurations.PostBetween.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langPost}"  VerticalAlignment="Center" Margin="5"/>
        </StackPanel>
        <CheckBox Content="{DynamicResource langCampaignHasStartDate}" 
                  IsChecked="{Binding JobConfigurations.IsCampaignHasStartDateChecked}"  Margin="5"/>
        <StackPanel Orientation="Horizontal" Margin="30,5" 
                    Visibility="{Binding JobConfigurations.IsCampaignHasStartDateChecked,Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource langStartDate}"  VerticalAlignment="Center" Margin="5"/>
            <control:DateTimePicker VerticalAlignment="Center"
                                    Margin="5" IsClockVisible="False"
                                    SelectedDate="{Binding JobConfigurations.CampaignStartDate}"/>
        </StackPanel>
        <CheckBox IsChecked="{Binding JobConfigurations.IsCampaignHasEndDateChecked}"
                  Content="{DynamicResource langCampaignHasEndDate}"  Margin="5"/>
        <StackPanel Orientation="Horizontal" Margin="30,5" 
                    Visibility="{Binding JobConfigurations.IsCampaignHasEndDateChecked,Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{DynamicResource langEndDate}"  VerticalAlignment="Center" Margin="5"/>
            <control:DateTimePicker VerticalAlignment="Center" 
                                    Margin="5" IsClockVisible="False" 
                                    SelectedDate="{Binding JobConfigurations.CampaignEndDate}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="5,0">
            <TextBlock Text="{DynamicResource DHlangDelayBetweenEachPost}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="0"
                               Value="{Binding JobConfigurations.DelayBetweenPost.StartValue}"
                               VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langTo}"  VerticalAlignment="Center" Margin="5"/>
            <control:NumericUpDown Minimum="{Binding JobConfigurations.DelayBetweenPost.StartValue}" Value="{Binding JobConfigurations.DelayBetweenPost.EndValue}" VerticalAlignment="Center"  Margin="5"/>
            <TextBlock Text="{DynamicResource langSeconds}"  VerticalAlignment="Center" Margin="5"/>
        </StackPanel>

        <Label Margin="0,5,0,0" FontWeight="Bold" Content="{DynamicResource DHlangSelectDayofWeekToPublish}"/>
        <ItemsControl ItemsSource="{Binding JobConfigurations.Weekday}" Margin="5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel IsItemsHost="True" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Content}" Margin="5"
                              IsChecked="{Binding IsContentSelected}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <CheckBox Content="{DynamicResource langRotateDays}"
                  IsChecked="{Binding JobConfigurations.IsRotateDayChecked}" Margin="10,5"/>

    </StackPanel>

</UserControl>

