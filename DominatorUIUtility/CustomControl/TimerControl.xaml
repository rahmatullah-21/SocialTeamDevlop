            <StackPanel  Margin="10,0,10,0">
                <ToggleButton IsChecked="{Binding ThursdayRunningTimeItemSource.IsEnabled}"  Style="{DynamicResource MetroFlatToggleButton}" Content="{Binding ThursdayRunningTimeItemSource.Thursday}"  Foreground="White" />
                <StackPanel Visibility="{ Binding ThursdayRunningTimeItemSource.IsEnabled,Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,10,0,10">
                    <ListBox ItemsSource="{Binding ThursdayRunningTimeItemSource.Timings}" >
