<UserControl x:Class="DominatorUIUtility.CustomControl.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             mc:Ignorable="d">
    <Grid Name="mainGrid"  Background="{DynamicResource AccentBaseColorBrush}"  Margin="5,0,5,0">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource langNameCampaign}"  Margin="10,0" Foreground="White" VerticalAlignment="Center"  FontSize="13" FontWeight="SemiBold"/>
            <TextBox Name="txtblkCampaignName" Margin="100,0,0,0" IsEnabled="{Binding IsCampaignNameEditable}" Foreground="White" Text="{Binding CampaignName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  BorderBrush="White" CaretBrush="White" VerticalAlignment="Center"  FontSize="13" Background="Transparent" Width="300" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="130" Height="24"
                    Margin="0,0,10,0"
                    BorderBrush="Black" BorderThickness="0" Style="{StaticResource ButtonStyle}" Background="#ef1d1d" Name="btnCancelEdit" 
                    Visibility="{Binding IsCancelEditVisible}" Click="BtnCancelEdit_OnClick">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="15" Height="15" Fill="White">
                            <Rectangle.OpacityMask>
                                <VisualBrush Visual="{StaticResource appbar_cancel}" Stretch="Fill"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="{DynamicResource langCancelEdit}" Margin="6,0"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            

            <!--<Button Width="130" Height="24" 
                        VerticalAlignment="Center" Grid.Column="2" Margin="0,0,10,0"
                        BorderBrush="Black" BorderThickness="0" Style="{StaticResource Button_style}" Background="#F44236"  Name="btnCancelEdit" 
                        Visibility="{Binding IsCancelEditVisible}" Click="BtnCancelEdit_OnClick"
                       >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Width="30" Height="35" HorizontalAlignment="Left" VerticalAlignment="Center" Source="/DominatorUIUtility;component/Images/remove.png" />
                    <TextBlock Text="{DynamicResource langCancelEdit}" VerticalAlignment="Center" HorizontalAlignment="Left"  FontSize="12" FontWeight="DemiBold" />
                </StackPanel>
            </Button>-->

            <Button Background="Transparent" Name="btnInfo" VerticalAlignment="Center" Margin="0,0,15,0" ToolTip="{DynamicResource langInfo}" Click="btnInfo_Click">
                <Rectangle Width="25" Height="25" Fill="White" >
                    <Rectangle.OpacityMask>
                            <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_information_circle}" />
                    </Rectangle.OpacityMask>
                </Rectangle>
             
                </Button>
           
        </StackPanel>
       
    </Grid>
</UserControl>
