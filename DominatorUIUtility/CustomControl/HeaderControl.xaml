<UserControl x:Class="DominatorUIUtility.CustomControl.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:utility="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore"
             mc:Ignorable="d" MinHeight="40">
    <Grid Name="mainGrid"  Background="{DynamicResource AccentBaseColorBrush}"  Margin="6,2,5,3">

        <StackPanel Orientation="Horizontal">
            <utility:TextPath Text="{DynamicResource LangKeyNameYourCampaign}" FontFamily="{StaticResource BuildTitleRgIt}" Margin="10,12,0,0" Fill="Black" Stroke="White"   FontSize="22" FontWeight="Bold"/>
            <TextBox Name="txtblkCampaignName" Background="{StaticResource AccentLightColorBrush}" Margin="50,0,0,0" IsEnabled="{Binding IsCampaignNameEditable}" Foreground="Black" FontFamily="{StaticResource BuildTitleRg}" Text="{Binding CampaignName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  BorderBrush="Black" BorderThickness="0.5" CaretBrush="White" VerticalAlignment="Center"  FontSize="13" Width="300" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ToggleButton VerticalAlignment="Center"  Foreground="White" Name="ClpsExpnd" Click="ClpsExpnd_OnClick">
                <ToggleButton.Style>
                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource MetroFlatToggleButton}">
                        <Setter Property="IsChecked" Value="{Binding IsExpanded,UpdateSourceTrigger=PropertyChanged}" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Background="WhiteSmoke" Height="30" Width="Auto"  BorderBrush="Gray" CornerRadius="10" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Margin="5,0,10,0" HorizontalAlignment="Center">
                                                <Image Height="20" Width="20" Source="/DominatorUIUtility;component/Images/collapse.png"/>
                                                <utility:TextPath Text="{DynamicResource LangKeyCollapseAll}" Margin="5,5,0,0" HorizontalAlignment="Center" FontFamily="{StaticResource BuildTitleRgIt}" Fill="White" Stroke="Black" StrokeThickness="0.9" FontSize="16" FontWeight="Bold"/>
                                                
                                            </StackPanel>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Background="WhiteSmoke" Height="30" Width="Auto"  BorderBrush="Gray" CornerRadius="10" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Margin="5,0,10,0" HorizontalAlignment="Center">
                                                <Image Height="20" Width="20" Source="/DominatorUIUtility;component/Images/expand.ico"/>
                                                <utility:TextPath Text="{DynamicResource LangKeyExpandAll}" Margin="5,5,0,0" HorizontalAlignment="Center" FontFamily="{StaticResource BuildTitleRgIt}" Fill="White" Stroke="Black" StrokeThickness="0.9"  FontSize="16" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
            <Button 
                    Margin="7,0,10,0"
                    BorderBrush="Black" BorderThickness="0" Background="Transparent"  Name="btnCancelEdit" 
                    Visibility="{Binding IsCancelEditVisible}" Command="{Binding CancelEditCommand}">
                <Button.Content>
                    <Border Margin="5"  Background="Red" Height="30" Width="150"  BorderBrush="Red" CornerRadius="10" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">

                            <Rectangle Margin="5" Width="15" Height="15" Fill="White">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Visual="{StaticResource appbar_cancel}" Stretch="Fill"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>

                            <utility:TextPath Text="{DynamicResource LangKeyCancelEditing}" Margin="0,5,0,0" HorizontalAlignment="Center" FontFamily="{StaticResource BuildTitleRgIt}" Fill="White" Stroke="Red" StrokeThickness="0.8"  FontSize="16" FontWeight="Bold"/>

                        </StackPanel>
                    </Border>
                </Button.Content>
            </Button>

            <Button Background="Transparent" Command="{Binding InfoCommand}">
                <Button.Content>
                    <!--<Rectangle Width="25" Height="25" Fill="White" 
                       x:Name="Info" Margin="10,0" ToolTip="{DynamicResource LangKeyInfo}">
                        <Rectangle.OpacityMask>
                            <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_information_circle}" />
                        </Rectangle.OpacityMask>
                    </Rectangle>-->
                    <Image Width="35" Height="35" Grid.Column="2" VerticalAlignment="Center" Margin="10,2,0,2" Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/info.png"/>
                </Button.Content>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
