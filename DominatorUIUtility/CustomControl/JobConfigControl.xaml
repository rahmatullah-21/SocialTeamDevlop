<UserControl x:Class="DominatorUIUtility.CustomControl.JobConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Name="MainGrid">
        <StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,8,0,0">
                <TextBlock  VerticalAlignment="Center" Text="{StaticResource langDelayEachOperation}"  />
                <controls:NumericUpDown Name="DelayOperationStartValue" Margin="5,5,5,0" Value="{Binding JobConfiguration.ActivitiesDelay.StartValue}" />
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource langTo}" />
                <controls:NumericUpDown  Margin="5,5,5,0" Minimum="{Binding Value, ElementName=DelayOperationStartValue}" Value="{Binding JobConfiguration.ActivitiesDelay.EndValue}" />
                <Label  VerticalAlignment="Center" Content="{DynamicResource langMinutes}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,8,0,0">
                <TextBlock    VerticalAlignment="Center" Text="{DynamicResource langDelayJob}"  />
                <controls:NumericUpDown Name="DelayJobStartValue" Margin="5,5,5,0" Value="{Binding JobConfiguration.JobsDelay.StartValue}" />
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource langTo}" />
                <controls:NumericUpDown  Margin="5,5,5,0" Minimum="{Binding Value, ElementName=DelayJobStartValue}" Value="{Binding JobConfiguration.JobsDelay.EndValue}" />
                <Label  VerticalAlignment="Center" Content="{DynamicResource langMinutes}"  />
            </StackPanel>

            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left" Margin="5,8,0,0">
                <Label Content="{Binding JobConfiguration.JobsActivityDisplayName}" />
                <controls:NumericUpDown Margin="5,5,5,0"  Value="{Binding JobConfiguration.JobsActivityCount.StartValue}" Name="MinJobFollowCount"/>
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource langTo}" />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.JobsActivityCount.EndValue}" Minimum="{Binding Value, ElementName=MinJobFollowCount}"/>
                <Label  VerticalAlignment="Center" Content="{DynamicResource langUsers}"  />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,8,0,0">
                <Label VerticalAlignment="Center" Content="{Binding  JobConfiguration.DaysActivityDisplayName}"  />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.DaysActivityCount.StartValue,UpdateSourceTrigger=PropertyChanged}" Name="MinActionsPerDay"/>
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"   Content="{DynamicResource langTo}" />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.DaysActivityCount.EndValue,UpdateSourceTrigger=PropertyChanged}" Minimum="{Binding Value, ElementName=MinActionsPerDay}"/>
                <Label  VerticalAlignment="Center" Content="{DynamicResource langUsers}"  />

            </StackPanel>

            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left" Margin="5,8,0,0">
                <Label    VerticalAlignment="Center" Content="{Binding  JobConfiguration.HoursActivityDisplayName}"  />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.HoursActivityCount.StartValue}" Name="OperationCountStartValue" />
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"   Content="{DynamicResource langTo}" />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.HoursActivityCount.EndValue}" Minimum="{Binding Value, ElementName=OperationCountStartValue}"/>
                <Label  VerticalAlignment="Center" Content="{DynamicResource langUsers}"  />

            </StackPanel>

            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left" Margin="5,8,0,0">
                <Label   VerticalAlignment="Center" Content="{ Binding  JobConfiguration.WeeksActivityDisplayName}"  />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.WeeksActivityCount.StartValue}" Name="CountPerWeekStartValue"/>
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"   Content="{DynamicResource langTo}" />
                <controls:NumericUpDown Margin="5,5,5,0" Value="{Binding JobConfiguration.WeeksActivityCount.EndValue}"  Minimum="{Binding Value, ElementName=CountPerWeekStartValue}"/>
                <Label  VerticalAlignment="Center" Content="{DynamicResource langUsers}"  />

            </StackPanel>

            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left" Margin="5,8,0,0">
                <CheckBox  VerticalAlignment="Center" Content="{DynamicResource langIncreaseEachDay}" IsChecked="{Binding JobConfiguration.IncreaseActivity.IsIncreaseCountChecked}"/>
                <controls:NumericUpDown Margin="5,5,5,5" Value="{Binding JobConfiguration.IncreaseActivity.IncreaseActivityCount}" Name="IncreaseMaxActionsPerDays" IsEnabled="{Binding JobConfiguration.IncreaseActivity.IsIncreaseCountChecked}"/>
                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource langUntilReach}"  />
                <controls:NumericUpDown Margin="5,5,5,5" Maximum="9999" Value="{Binding JobConfiguration.IncreaseActivity.UntilMaxCountReached}" Minimum="{Binding Value, ElementName=IncreaseMaxActionsPerDays}" IsEnabled="{Binding JobConfiguration.IncreaseActivity.IsIncreaseCountChecked}"/>
                <Label  VerticalAlignment="Center"  Content="{Binding  JobConfiguration.IncreaseActivityDisplayName}"  />
            </StackPanel>

            <StackPanel>
                <Label Margin="0,5,0,0" FontWeight="Bold" Content="{DynamicResource langDayofWeekWhenToOperate}"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <ListBox ItemsSource="{Binding JobConfiguration.RunningTime}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel IsItemsHost="True" Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <local:DayTimerControl RunningTimes="{Binding Path=.}"></local:DayTimerControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                </StackPanel>
                 
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
