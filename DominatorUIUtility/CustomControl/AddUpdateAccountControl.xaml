<UserControl x:Class="DominatorUIUtility.CustomControl.AddUpdateAccountControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:passwordHelper="clr-namespace:DominatorUIUtility.Behaviours"
             xmlns:validation="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" x:Name="UserControlAddUpdateAccount"
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:enums="clr-namespace:DominatorHouseCore.Enums;assembly=DominatorHouseCore">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringLengthToBooleanConverter x:Key="LengthToBooleanConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Top">
            <Grid.Resources>
                <ControlTemplate x:Key="ErrorTemplate">
                    <StackPanel Orientation="Horizontal">
                        <AdornedElementPlaceholder x:Name="ErrorHolder">
                            <Border BorderBrush="red" BorderThickness="1" />
                        </AdornedElementPlaceholder>
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Margin="10,0,0,0"
                                   Text="{Binding ElementName=ErrorHolder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                   Foreground="Red" />
                    </StackPanel>
                </ControlTemplate>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="5*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Name="TextBlockPageTitle" Margin="4" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme1}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="TxtblockSelectNetWork" Text="{DynamicResource LangKeySocialNetwork}" Width="120"
                           Margin="5" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                <ComboBox Name="ComboBoxSocialNetworks" Grid.Column="1" Width="230" Height="30" SelectedIndex="0"
                          SelectedItem="{Binding AccountNetwork}" />
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="txtblockGroupName" Text="{DynamicResource LangKeyGroupName}" Width="120" Margin="5"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                <TextBox Name="txtGroupName" Text="{Binding AccountGroup.Content}"
                         controls:TextBoxHelper.Watermark="{DynamicResource LangKeyEnterGroupName}"
                         Width="230" FontSize="13" FontWeight="SemiBold" Margin="5"
                         Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                         Height="30" Grid.Column="1" KeyDown="OnKeyDown" />
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="txtblockAccountName" Text="{DynamicResource LangKeyAccountName}" Width="120"
                           Margin="5" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                <TextBox Name="txtAccountName" Text="{Binding AccountName}"
                         controls:TextBoxHelper.Watermark="{DynamicResource LangKeyAccountNikeName}"
                         Width="230" FontSize="13" FontWeight="SemiBold" Margin="5"
                         Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                         Height="30" Grid.Column="1" KeyDown="OnKeyDown" />
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="txtblockUserName" Text="{DynamicResource LangKeyEmailIdUsername}" Width="120"
                           Margin="5" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                <TextBox Name="txtUserName" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                         controls:TextBoxHelper.Watermark="{DynamicResource LangKeyEnterUserName}" Width="230"
                         FontSize="13" FontWeight="SemiBold"
                         Margin="5" Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                         VerticalAlignment="Center" Height="30" Grid.Column="1"
                         KeyDown="OnKeyDown">
                    <TextBox.Text>
                        <Binding Path="UserName" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validation:ValidationHelper Sender="txtUserName" ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </Grid>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="txtblockPassword" Text="{DynamicResource LangKeyPassword}" Width="120" FontSize="13"
                           Margin="5" FontWeight="SemiBold" Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                           VerticalAlignment="Center" />
                <PasswordBox Name="txtPassword" passwordHelper:PasswordBoxHelper.Attach="True"
                             Style="{StaticResource MetroButtonRevealedPasswordBox}"
                             Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                             controls:TextBoxHelper.Watermark="{DynamicResource LangKeyEnterPassword}"
                             KeyDown="OnKeyDown"
                             Width="230" FontSize="13" FontWeight="SemiBold" Margin="5"
                             Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                             Height="30" Grid.Column="1">
                    <passwordHelper:PasswordBoxHelper.Password>
                        <Binding Path="Password" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                            <Binding.ValidationRules>
                                <validation:ValidationHelper Sender="txtPassword" ValidatesOnTargetUpdated="True" />
                            </Binding.ValidationRules>
                        </Binding>
                    </passwordHelper:PasswordBoxHelper.Password>

                </PasswordBox>

            </Grid>
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5*" />
                </Grid.ColumnDefinitions>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccountNetwork}"
                                         Value="{x:Static enums:SocialNetworks.Youtube}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <!--<DataTrigger Binding="{Binding AccountNetwork}"  Value="{x:Static enums:SocialNetworks.Gplus}" >
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>-->
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <TextBlock Text="{DynamicResource LangKeyAlternateEmail}" Width="120" Margin="5" FontSize="13"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                           VerticalAlignment="Center" />
                <TextBox Width="230" Grid.Column="1" Text="{Binding AlternateEmail}" FontWeight="SemiBold"
                         controls:TextBoxHelper.Watermark="{DynamicResource LangKeyAlternateEmail}"
                         Margin="5" Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                         VerticalAlignment="Center" Height="30" KeyDown="OnKeyDown" />
                <!--<TextBox controls:TextBoxHelper.Watermark="{DynamicResource LangKeyAlternateEmail}" Width="230" FontSize="13" FontWeight="SemiBold" 
                     Margin="5" Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"  Height="30" Text="{Binding AlternateEmail}" Grid.Column="1"
                     KeyDown="OnKeyDown"/>-->
            </Grid>
            <Grid Grid.Row="7">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccountNetwork}"
                                         Value="{x:Static enums:SocialNetworks.Instagram}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <CheckBox Content="{DynamicResource LangKeyTwoFactorLoginRequired}"
                          IsChecked="{Binding IsChkTwoFactorLogin}" Width="180" FontWeight="SemiBold"
                          HorizontalAlignment="Left" Margin="6,0,0,5" />
            </Grid>
            <CheckBox Name="CheckBoxShowAdvance" IsChecked="False" Grid.Row="8"
                      Content="{DynamicResource LangKeyShowAdvance}" HorizontalAlignment="Left" Width="120"
                      FontWeight="SemiBold" Margin="6,0,0,5" />
            <Grid Grid.Row="9" Name="GridAdvanceOption" Margin="0,0,0,10" Height="Auto"
                  Visibility="{Binding IsChecked,ElementName=CheckBoxShowAdvance,Converter={StaticResource BooleanToVisibilityConverter},Mode=TwoWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtblockProxyGroup" Text="{DynamicResource LangKeyProxyGroup}" Width="120"
                               Margin="5" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                    <TextBox Name="txtProxyGroup" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                             KeyDown="OnKeyDown"
                             Text="{Binding AccountProxy.ProxyGroup}" Width="230" FontSize="13" Margin="5"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                             Height="30" Grid.Column="1"
                             controls:TextBoxHelper.Watermark="{DynamicResource LangKeyTypeProxyGroup}" />
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtblockProxyAddress" Text="{DynamicResource LangKeyProxyAddress}" Width="120"
                               Margin="5" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                    <TextBox Name="txtProxyAddress" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                             KeyDown="OnKeyDown"
                             Text="{Binding AccountProxy.ProxyIp}" Width="230" FontSize="13" Margin="5"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                             Height="30" Grid.Column="1"
                             controls:TextBoxHelper.Watermark="{DynamicResource LangKeyTypeProxyIp}" />


                    <!--<TextBox Name="txtProxyAddress" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"  KeyDown="OnKeyDown"
                         controls:TextBoxHelper.Watermark="Format:{255.255.255.255}" Width="230" FontSize="13" Margin="5" FontWeight="SemiBold" Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"  Height="30" Grid.Column="1">
                    <TextBox.Text>
                        <Binding Path="AccountProxy.ProxyIp" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validation:ValidationHelper Sender="txtProxyAddress" ValidatesOnTargetUpdated="True"/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>-->
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtblockProxyPort" Text="{DynamicResource LangKeyProxyPort}" Margin="5"
                               Width="120" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                    <TextBox Name="txtProxyPort" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                             KeyDown="OnKeyDown"
                             controls:TextBoxHelper.Watermark="{DynamicResource LangKeyTypeProxyPort}" Width="230"
                             FontSize="13" FontWeight="SemiBold"
                             Margin="5" Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                             VerticalAlignment="Center" Height="30" Grid.Column="1">
                        <TextBox.Text>
                            <Binding Path=" AccountProxy.ProxyPort" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validation:ValidationHelper Sender="txtProxyPort" ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                </Grid>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtblockProxyUserName" Text="{DynamicResource LangKeyProxyUsername}" Width="120"
                               FontSize="13" Margin="5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                    <TextBox Name="txtProxyUserName" Text="{Binding AccountProxy.ProxyUsername}"
                             controls:TextBoxHelper.Watermark="{DynamicResource LangKeyTypeProxyUsername}" Width="230"
                             FontSize="13" FontWeight="SemiBold" Margin="5"
                             Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                             VerticalAlignment="Center" Height="30" Grid.Column="1" KeyDown="OnKeyDown">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                <Setter Property="IsEnabled" Value="false" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition
                                                Binding="{Binding ElementName=txtProxyAddress, Path=(Validation.HasError)}"
                                                Value="false" />
                                            <Condition
                                                Binding="{Binding ElementName=txtProxyPort, Path=(Validation.HasError)}"
                                                Value="false" />
                                            <Condition
                                                Binding="{Binding ElementName=txtProxyAddress, 
                                            Path=Text.Length,Converter={StaticResource LengthToBooleanConverter}}"
                                                Value="true" />
                                            <Condition
                                                Binding="{Binding ElementName=txtProxyPort, Path=Text.Length,
                                            Converter={StaticResource LengthToBooleanConverter}}"
                                                Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="true" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtblockProxyPassword" Text="{DynamicResource LangKeyProxyPassword}" Width="120"
                               FontSize="13" Margin="5,11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center" />
                    <PasswordBox Name="txtProxyPassword" passwordHelper:PasswordBoxHelper.Attach="True"
                                 controls:TextBoxHelper.Watermark="{DynamicResource LangKeyTypeProxyPassword}"
                                 KeyDown="OnKeyDown"
                                 Width="230" FontSize="13" FontWeight="SemiBold" Margin="5,5,4.693,5"
                                 Foreground="{DynamicResource TextColorBrushAccordingTheme}" VerticalAlignment="Center"
                                 Height="30" Grid.Column="1"
                                 Grid.ColumnSpan="1">
                        <!--<PasswordBox.Style>
                        <Style BasedOn="{StaticResource MetroButtonRevealedPasswordBox}" TargetType="PasswordBox">
                            <Setter Property="IsEnabled" Value="false" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ElementName=txtProxyAddress, Path=(Validation.HasError)}" Value="false" />
                                        <Condition Binding="{Binding ElementName=txtProxyPort, Path=(Validation.HasError)}" Value="false" />
                                        <Condition Binding="{Binding ElementName=txtProxyAddress, 
                                            Path=Text.Length,Converter={StaticResource LengthToBooleanConverter}}" Value="true" />
                                        <Condition Binding="{Binding ElementName=txtProxyPort, Path=Text.Length,
                                            Converter={StaticResource LengthToBooleanConverter}}" Value="true" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="true" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>-->
                        <passwordHelper:PasswordBoxHelper.Password>
                            <Binding Path="AccountProxy.ProxyPassword" UpdateSourceTrigger="PropertyChanged"
                                     Mode="TwoWay" />
                        </passwordHelper:PasswordBoxHelper.Password>
                    </PasswordBox>
                </Grid>
                <Grid Grid.Row="5">
                    <CheckBox Margin="15,5,0,0" x:Name="RunThroughBrowserAutomation"
                              Content="{StaticResource LangKeyRunAllActivityThroughBrowser}">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding DominatorAccountModel.AccountBaseModel.AccountNetwork}"
                                        Value="{x:Static enums:SocialNetworks.Instagram}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding DominatorAccountModel.AccountBaseModel.AccountNetwork}"
                                        Value="{x:Static enums:SocialNetworks.TikTok}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding DominatorAccountModel.AccountBaseModel.AccountNetwork}"
                                        Value="{x:Static enums:SocialNetworks.Facebook}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </Grid>
                <Grid Grid.Row="6" x:Name="CopyJsonCookieGrid">
                    <StackPanel Margin="15,5,0,0" Orientation="Vertical" HorizontalAlignment="Left">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding DominatorAccountModel.AccountBaseModel.AccountNetwork}"
                                        Value="{x:Static enums:SocialNetworks.Instagram}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding DominatorAccountModel.AccountBaseModel.AccountNetwork}"
                                        Value="{x:Static enums:SocialNetworks.TikTok}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="copyJsonCookieCheckBox"
                                      Content="{StaticResource LangKeyPasteJsonCookiesLogin}" />
                            <Rectangle Width="16" Height="16" Fill="IndianRed" Margin="5,0"
                                       ToolTip="{StaticResource LangKeyStepsToGetJsonCookies}"
                                       ToolTipService.ShowDuration="60000">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Visual="{StaticResource appbar_book_perspective_help}" Stretch="Fill" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ElementName=copyJsonCookieCheckBox,Path=IsChecked,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox Margin="0,5,0,15" TextWrapping="Wrap" AcceptsReturn="True"
                                     Name="CopiedJsonCookies"
                                     VerticalScrollBarVisibility="Auto" VerticalAlignment="Bottom"
                                     HorizontalAlignment="Center" Width="300" MaxHeight="80"
                                     BorderBrush="{DynamicResource AccentBaseColorBrush}" BorderThickness="1.5" />
                            <Button VerticalAlignment="Top" Margin="7" x:Name="SaveCopiedCookies"
                                    HorizontalAlignment="Left" Height="24" Background="DarkGreen"
                                    Click="SaveCopiedCookies_Click" ToolTipService.Placement="Right">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Margin="1,1,4,1" Width="12" Height="12" Fill="White">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Visual="{StaticResource appbar_save}" Stretch="Fill" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock Text="{DynamicResource LangKeyAdd}" VerticalAlignment="Center"
                                                   Foreground="White" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button VerticalAlignment="Top" Margin="7" x:Name="ClearCopiedCookies"
                                    HorizontalAlignment="Left" Height="24" Background="IndianRed"
                                    Click="ClearCopiedCookies_Click" ToolTipService.Placement="Right">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Margin="1,1,4,1" Width="12" Height="12" Fill="White">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Visual="{StaticResource appbar_clear}" Stretch="Fill" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock Text="{DynamicResource LangKeyRemove}" VerticalAlignment="Center"
                                                   Foreground="White" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </Grid>
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                    <Button x:Name="btnSave" x:FieldModifier="public" Margin="0,0,10,10" Foreground="White">
                        <Button.Style>
                            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                <Setter Property="IsEnabled" Value="false" />
                                <Setter Property="Background" Value="Gray" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition
                                                Binding="{Binding ElementName=txtUserName, Path=(Validation.HasError)}"
                                                Value="false" />
                                            <Condition
                                                Binding="{Binding ElementName=txtPassword, Path=(Validation.HasError)}"
                                                Value="false" />
                                            <!--<Condition Binding="{Binding ElementName=txtProxyAddress, Path=(Validation.HasError)}" Value="false" />-->
                                            <Condition
                                                Binding="{Binding ElementName=txtProxyPort, Path=(Validation.HasError)}"
                                                Value="false" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="true" />
                                        <Setter Property="Control.Background" Value="Green" />
                                    </MultiDataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnCancel" x:FieldModifier="public" Margin="0,0,8,10" Background="#ef1d1d"
                            IsCancel="True">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="15" Height="15" Fill="White">
                                    <Rectangle.OpacityMask>
                                        <VisualBrush Visual="{StaticResource appbar_cancel}" Stretch="Fill" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="Close" Margin="6,0" Foreground="White"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>