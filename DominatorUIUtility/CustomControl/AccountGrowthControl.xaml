                                            <ContentControl>
                                                <ContentControl.Style>

                                                    <Style TargetType="{x:Type ContentControl}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Style.Triggers>





                                                            <DataTrigger Binding="{Binding Path=DisplayColumnValue10, Converter={StaticResource objNegationConvertor}}" Value="true" >
                                                                <Setter Property="Content" >
                                                                    <Setter.Value>
                                                                        <Rectangle Fill="#28A745" Width="20" Height="20">
