                                                                        <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                            <Rectangle.Resources>
                                                                                <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                            </Rectangle.Resources>
                                                                            <Rectangle.OpacityMask>
                                                                                <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                            </Rectangle.OpacityMask>
                                                                        </Rectangle>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Path=DisplayColumnValue6, Converter={StaticResource objNegationConvertor}}" Value="false">
                                                                <Setter Property="Content" >
                                                                    <Setter.Value>
                                                                        <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                            <Rectangle.Resources>
