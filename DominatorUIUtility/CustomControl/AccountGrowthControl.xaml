                                                                            <Setter.Value>
                                                                                <Rectangle Fill="OrangeRed" Width="20" Height="20">
                                                                                    <Rectangle.Resources>
                                                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                    </Rectangle.Resources>
                                                                                    <Rectangle.OpacityMask>
                                                                                        <VisualBrush Visual="{StaticResource appbar_social_reddit}" Stretch="Fill" />
                                                                                    </Rectangle.OpacityMask>
                                                                                </Rectangle>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding Path=AccountBaseModel.AccountNetwork}" Value="{x:Static enums:SocialNetworks.LinkedIn}">
                                                                        <Setter Property="Content" >
                                                                            <Setter.Value>
                                                                                <Rectangle Fill="DodgerBlue" Width="20" Height="20">
                                                                                    <Rectangle.Resources>
                                                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                    </Rectangle.Resources>
                                                                                    <Rectangle.OpacityMask>
                                                                                        <VisualBrush Visual="{StaticResource appbar_social_linkedin_variant}" Stretch="Fill" />
                                                                                    </Rectangle.OpacityMask>
                                                                                </Rectangle>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Path=AccountBaseModel.AccountNetwork}" Value="{x:Static enums:SocialNetworks.Gplus}">
                                                                        <Setter Property="Content" >
                                                                            <Setter.Value>
                                                                                <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                                                    <Rectangle.Resources>
                                                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                    </Rectangle.Resources>
                                                                                    <Rectangle.OpacityMask>
                                                                                        <VisualBrush Visual="{StaticResource appbar_googleplus}" Stretch="Fill" />
                                                                                    </Rectangle.OpacityMask>
                                                                                </Rectangle>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding Path=AccountBaseModel.AccountNetwork}" Value="{x:Static enums:SocialNetworks.Youtube}">
                                                                        <Setter Property="Content" >
                                                                            <Setter.Value>
                                                                                <Rectangle Fill="#FF0000" Width="20" Height="20">
                                                                                    <Rectangle.Resources>
                                                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                    </Rectangle.Resources>
                                                                                    <Rectangle.OpacityMask>
                                                                                        <VisualBrush Visual="{StaticResource appbar_youtube}" Stretch="Fill" />
                                                                                    </Rectangle.OpacityMask>
                                                                                </Rectangle>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding Path=AccountBaseModel.AccountNetwork}" Value="{x:Static enums:SocialNetworks.Tumblr}">
                                                                        <Setter Property="Content" >
                                                                            <Setter.Value>
                                                                                <Rectangle Fill="DimGray" Width="16" Height="20">
                                                                                    <Rectangle.Resources>
                                                                                        <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                    </Rectangle.Resources>
                                                                                    <Rectangle.OpacityMask>
                                                                                        <VisualBrush Visual="{StaticResource appbar_social_tumblr}" Stretch="Fill" />
                                                                                    </Rectangle.OpacityMask>
                                                                                </Rectangle>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                    <CheckBox IsChecked="{Binding IsAccountManagerAccountSelected}" Margin="10,0"
                                                  Content="{Binding (ItemsControl.AlternationIndex),
                                                  RelativeSource={RelativeSource AncestorType=ListViewItem},
                                                  Converter={StaticResource IndexToRowNoConverter}}" Foreground="{DynamicResource AccentBaseColorBrush}"/>
                                                </StackPanel>

                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn  Header="{DynamicResource LangKeyUsername}" DisplayMemberBinding="{Binding AccountBaseModel.UserName}"/>


                                    <GridViewColumn Header="{DynamicResource LangKeyGrowthColumn1}" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1,1,0,0" BorderBrush="LightGray" Margin="-6,-2,-6,-2">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding DisplayColumnValue1}"/>
                                                        <!--<Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding AccountBaseModel.AccountGroup.Content}"/>-->
                                                        <ContentControl>
                                                            <ContentControl.Style>
                                                                <Style TargetType="{x:Type ContentControl}">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue6, Converter={StaticResource objNegationConvertor}}" Value="true">
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue6, Converter={StaticResource objNegationConvertor}}" Value="false">
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_down_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <Label Name="newFollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding Path=DisplayColumnValue6, Converter={StaticResource objPositiveValueConvertor}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource LangKeyGrowthColumn2}" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1,1,0,0" BorderBrush="LightGray" Margin="-6,-2,-6,-2">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding DisplayColumnValue2}"/>
                                                        <!--<Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="2"/>-->
                                                        <ContentControl>
                                                            <ContentControl.Style>
                                                                <Style TargetType="{x:Type ContentControl}">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                    <Style.Triggers>





                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue7, Converter={StaticResource objNegationConvertor}}" Value="true">
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue7, Converter={StaticResource objNegationConvertor}}" Value="false" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_down_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <Label Name="newFollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding Path=DisplayColumnValue7, Converter={StaticResource objPositiveValueConvertor}}"/>

                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource LangKeyGrowthColumn3}" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1,1,0,0" BorderBrush="LightGray" Margin="-6,-2,-6,-2">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding DisplayColumnValue3}"/>
                                                        <ContentControl>
                                                            <ContentControl.Style>

                                                                <Style TargetType="{x:Type ContentControl}">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                    <Style.Triggers>





                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue8, Converter={StaticResource objNegationConvertor}}" Value="true" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue8, Converter={StaticResource objNegationConvertor}}" Value="false" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_down_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <Label Name="newFollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding Path=DisplayColumnValue8, Converter={StaticResource objPositiveValueConvertor}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource LangKeyGrowthColumn4}" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1,1,0,0" BorderBrush="LightGray" Margin="-6,-2,-6,-2">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding DisplayColumnValue3}"/>
                                                        <ContentControl>
                                                            <ContentControl.Style>

                                                                <Style TargetType="{x:Type ContentControl}">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                    <Style.Triggers>





                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue9, Converter={StaticResource objNegationConvertor}}" Value="true" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue9, Converter={StaticResource objNegationConvertor}}" Value="false" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_down_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <Label Name="newFollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding Path=DisplayColumnValue9, Converter={StaticResource objPositiveValueConvertor}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource LangKeyGrowthColumn5}" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1,1,0,0" BorderBrush="LightGray" Margin="-6,-2,-6,-2">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Name="oldfollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding DisplayColumnValue3}"/>
                                                        <ContentControl>
                                                            <ContentControl.Style>

                                                                <Style TargetType="{x:Type ContentControl}">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                                    <Style.Triggers>





                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue10, Converter={StaticResource objNegationConvertor}}" Value="true" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#28A745" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_up_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Path=DisplayColumnValue10, Converter={StaticResource objNegationConvertor}}" Value="false" >
                                                                            <Setter Property="Content" >
                                                                                <Setter.Value>
                                                                                    <Rectangle Fill="#DC3545" Width="20" Height="20">
                                                                                        <Rectangle.Resources>
                                                                                            <SolidColorBrush x:Key="BlackBrush" Color="Black" />
                                                                                        </Rectangle.Resources>
                                                                                        <Rectangle.OpacityMask>
                                                                                            <VisualBrush Visual="{StaticResource appbar_down_arrow}" Stretch="Fill" />
                                                                                        </Rectangle.OpacityMask>
                                                                                    </Rectangle>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <Label Name="newFollowerCountLabel" HorizontalContentAlignment="Left" Margin="10,0,10,0" 
               Content="{Binding Path=DisplayColumnValue10, Converter={StaticResource objPositiveValueConvertor}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>


                                </GridView>




                            </ListView.View>



                        </ListView>
                        <!--Help section-->
                        <Controls:FlyoutsControl>
                            <Controls:Flyout Header="{DynamicResource LangKeyModuleDescription}" Position="Right" Visibility="Collapsed"  x:Name="HelpFlyout" Theme="Accent" FontWeight="Bold"
                                 Foreground="White"  Width="300" BorderBrush="Black" BorderThickness="2"   IsOpen="{Binding IsOpenHelpControl}"  Background="{DynamicResource AccentBaseColorBrush}" FontSize="10" >
                                <local:HelpControl ModuleDescription="Text for account"
                                                 VideoTutorial="{Binding VideoTutorialLink}" KnowledgeBaseLink="{Binding KnowledgeBaseLink}" 
                                                 ContactSupportLink="{Binding ContactSupportLink}" />
                            </Controls:Flyout>
                        </Controls:FlyoutsControl>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
