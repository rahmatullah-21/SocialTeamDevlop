                                                    <Style TargetType="{x:Type ContentControl}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Style.Triggers>





                                                            <DataTrigger Binding="{Binding Path=DisplayColumnValue8, Converter={StaticResource objNegationConvertor}}" Value="true" >
