<UserControl x:Class="DominatorUIUtility.CustomControl.AccountGrowthControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:utility="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore"
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:enums="clr-namespace:DominatorHouseCore.Enums;assembly=DominatorHouseCore"
             xmlns:dhenums="clr-namespace:DominatorHouseCore.Enums.DHEnum;assembly=DominatorHouseCore"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Name="AccountModule"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:IndexToRowNoConverter x:Key="IndexToRowNoConverter"/>
        <converters:IsPositiveValueConvertor x:Key="objNegationConvertor"/>
        <converters:PositiveValueConvertor x:Key="objPositiveValueConvertor"/>
        <ObjectDataProvider x:Key="dataFromEnum" MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="dhenums:GrowthPeriod"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid Name="MainGrid">
        <TabControl ItemContainerStyle="{StaticResource TabItemStyle}">
            <TabItem Header="{DynamicResource LangKeyAccountGrowth}" >
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.35*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>


                        <StackPanel Background="{DynamicResource AccentColorBrush}" Orientation="Horizontal">
                            <Label  
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" 
                               FontSize="16"
                               FontWeight="SemiBold" VerticalContentAlignment="Center"
                               Foreground="White" Margin="5,0,0,0"
                               Content="Account Growth Charts" />
                        </StackPanel>


                        <Grid Grid.Column="1" Background="{DynamicResource AccentColorBrush}">

                            <StackPanel  Background="{DynamicResource AccentColorBrush}" Orientation="Horizontal"  VerticalAlignment="Center" Margin="0,0,10,0">
                                <Label   VerticalAlignment="Top"  Foreground="White" Content="Select Account" HorizontalAlignment="Right" Height="25"/>

                                <ComboBox  Name="cmbGrowthAcount"  Width="200"  ItemsSource="{Binding AccountCollectionView}"   VerticalAlignment="Top" Margin="6,0,0,0" Height="25"                                       
                                               SelectedIndex="0" SelectionChanged="cmbGrowthAcount_SelectionChanged"   DisplayMemberPath="AccountBaseModel.UserName" 
                                               SelectedValuePath="AccountId"  SelectedValue="{Binding GrowthChartAccountNumber}" />


                                <Label  VerticalAlignment="Top"  Foreground="White" Content="Select Period"  HorizontalAlignment="Right" Height="25"/>

                                <ComboBox  Name="cmbGrowthChartPeriod" Width="200"  VerticalAlignment="Top" Margin="6,0,0,0" Height="25"   
                                               ItemsSource="{Binding GrowthChartPeriods}"                                   
                                               SelectedIndex="0" SelectedValue="{Binding GrowthChartPeriod}"  SelectionChanged="cmbGrowthChartPeriod_SelectionChanged"/>
                                <Label VerticalAlignment="Top"  Foreground="White" Content="Select Type"  HorizontalAlignment="Right" Height="25"/>

                                <ComboBox  Name="cmbGrowthChartType" Width="100"  VerticalAlignment="Top" Margin="6,0,0,0" Height="25"  
                                               ItemsSource="{Binding GrowthChartTypes}"                                   
                                               SelectedValue="{Binding GrowthChartType}" SelectionChanged="cmbGrowthChartType_SelectionChanged"/>

                            </StackPanel>

                        </Grid>

                    </Grid>
                    <Grid Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0" HorizontalAlignment="Left" >
                            <StackPanel Orientation="Horizontal"    Margin="0,0,0,0">
                                <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Hidden" Margin = "5">
                                    <ItemsControl x:Name="list" ItemsSource="{Binding GrowthProperties}" Focusable="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Name="CheckBoxZone" Content="{Binding PropertyName}"
                                              Tag="{Binding PropertyValue}"  Checked="HandleGrowthTypeCheck"  
                                              Unchecked = "HandleGrowthTypeUnCheck"  Margin="0,5,5,0" IsChecked="True"/>
                                            </DataTemplate>
                                            <!--<HierarchicalDataTemplate>
                                        <Border Padding="5,0,0,2">
                                            <ListBox Name="mylistBox"  >
                                                <CheckBox Name="CheckBoxZone" Content="{Binding PropertyName,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                                                          Tag="{Binding PropertyValue,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"  Checked="HandleGrowthTypeCheck"  
                                                          Unchecked = "HandleGrowthTypeUnCheck"  Margin="0,5,0,0" IsChecked="True"/>
                                            </ListBox>
                                        </Border>
                                    </HierarchicalDataTemplate>-->
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                            </StackPanel>

                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2">

                        <!--<StackPanel Orientation="Horizontal" Margin="0,0,15,0" HorizontalAlignment="Right" Background="{DynamicResource AccentColorBrush}">
                    <StackPanel Orientation="Horizontal"    Margin="0,5,0,10">
                        <Label   VerticalAlignment="Top"  Foreground="White" Content="{DynamicResource langFilterGrowth}" HorizontalAlignment="Right" Height="25"/>

                       
                    </StackPanel>

                </StackPanel>-->
                        <lvc:CartesianChart Name="chart" Series="{Binding SeriesCollection}" LegendLocation="Right"  >
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Growth" LabelFormatter="{Binding YFormatter}" MaxValue="{Binding YMaxValue}"></lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Month" Labels="{Binding Labels}"></lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                        </lvc:CartesianChart>


                    </Grid>


                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource LangKeyAccountGrowth}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.35*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>


                        <StackPanel Background="{DynamicResource AccentColorBrush}" Orientation="Horizontal">
                            <Label  
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" 
                               FontSize="16"
                               FontWeight="SemiBold" VerticalContentAlignment="Center"
                               Foreground="White" Margin="5,0,0,0"
                               Content="{DynamicResource LangKeyAccountGrowth}" />
                        </StackPanel>


                        <Grid Grid.Column="1" Background="{DynamicResource AccentColorBrush}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0" HorizontalAlignment="Right" Background="{DynamicResource AccentColorBrush}">
                                <StackPanel Orientation="Horizontal"    Margin="0,5,0,10">
                                    <Label   VerticalAlignment="Top"  Foreground="White" Content="{DynamicResource LangKeyFilterBy}" HorizontalAlignment="Right" Height="25"/>

                                    <ComboBox  Name="cmbGrowthPeriod" ItemsSource="{Binding Source={StaticResource dataFromEnum}}" Width="200"  VerticalAlignment="Top" Margin="6,0,0,0" Height="25"                                       
                                      SelectedIndex="0" SelectionChanged="cmbGrowthPeriod_SelectionChanged" DropDownClosed="CmbboxGrowthPeriod_OnDropDownClosed">
                                        <!--SelectedItem="{Binding SelectedOption, Mode=TwoWay}"-->
                                        <!--<ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"></TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>-->

                                    </ComboBox>
                                </StackPanel>

                            </StackPanel>
                        </Grid>

                    </Grid>
                    <!--Data grid view-->
                    <Grid Grid.Row="1">
                        <ListView x:Name="AccountListView" ItemsSource="{Binding AccountCollectionView}" 
                      AlternationCount="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Foreground="{DynamicResource AccentBaseColorBrush}">
                            <!--<ListView.ItemContainerStyle>
                    -->
                            <!--<Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItems}">
                        <EventSetter Event="ContextMenu.ContextMenuOpening" Handler="Row_ContextMenuOpening"/>
                        -->
                            <!--<Setter Property="Foreground" Value="White"/>-->
                            <!--
                        <Setter Property="Height" Value="30"/>

                    </Style>-->
                            <!--
                </ListView.ItemContainerStyle>-->

                            <ListView.View>
                                <GridView >
                                    <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" >
                                        <GridViewColumn.CellTemplate>
