<UserControl x:Class="DominatorUIUtility.CustomControl.AccountCustomControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             xmlns:utility="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:enums="clr-namespace:DominatorHouseCore.Enums;assembly=DominatorHouseCore"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:uiExtensions="clr-namespace:DominatorHouseCore.UIExtensions;assembly=DominatorHouseCore"
             xmlns:viewModel="clr-namespace:DominatorUIUtility.ViewModel"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
             Name="AccountModule"
             mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="SizeChanged" >
            <i:InvokeCommandAction Command="{Binding AddSingleAccountCommand,ElementName=AccountModule}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <converters:IndexToRowNoConverter x:Key="IndexToRowNoConverter"/>
        <system:Boolean x:Key="True">True</system:Boolean>
        <system:Boolean x:Key="False">False</system:Boolean>
        <converters:AccountsFilterConverter x:Key="AccountsFilterConverter"/>
        <converters:VisibleIfEqualConverter x:Key="VisibleIfNetworkIsInstagramConverter" Expected="{x:Static enums:SocialNetworks.Instagram}"/>
        <converters:VisibleIfEqualConverter x:Key="VisibleIfNetworkIsNotInstagramConverter" Expected="{x:Static enums:SocialNetworks.Instagram}" Inversed="True"/>
        <converters:VisibleIfEqualConverter x:Key="VisibleIfNetworkIsNotTikTokConverter" Expected="{x:Static enums:SocialNetworks.TikTok}" Inversed="True"/>
        <converters:VisibleIfEqualConverter x:Key="VisibleIfNetworkIsTwitterConverter" Expected="{x:Static enums:SocialNetworks.Twitter}"/>
        <converters:VisibleIfEqualConverter x:Key="VisibleIfNetworkIsSocialConverter" Expected="{x:Static enums:SocialNetworks.Admin}"/>
        <converters:SocialNetworkToVisualBrushConverter x:Key="SocialNetworkToVisualBrushConverter" />
        <converters:SocialNetworkToColorBrushConverter x:Key="SocialNetworkToColorBrushConverter" />
        <converters:BooleanToAutomationStatusConverter x:Key="BooleanToAutomationStatusConverter" />
        <converters:PinterestAccountTypeToStatusConverter x:Key="PinterestAccountTypeToStatusConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:SocialNetworkToLinkConverter x:Key="SocialNetworkToLinkConverter" />
        <converters:SelectedNetworkToVisibilityConverter x:Key="SelectedNetworkToVisibilityConverter"/>
        <converters:PinterestAccountTypeToVisibilityConverter x:Key="PinterestAccountTypeToVisibilityConverterInverted" IsInverse="True"/>
        <converters:PinterestAccountTypeToVisibilityConverter x:Key="PinterestAccountTypeToVisibilityConverter"/>
        <converters:BrowserAutomationConverter x:Key="BrowserAutomationConverter"/>
        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:Key="VisiblityStyle">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.Success}">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>




        <Rectangle x:Key="DetailsIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_book_open_hardcover}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="DeleteIcon" Fill="IndianRed" Width="17" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_delete}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="BrowseLoginIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_browser}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="GoToToolsIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="18">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_tools}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="CheckStatusIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="18">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_page_search}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="UpdateFriendshipIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_group}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="GotoAccountProvideIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_page_edit}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="InstEditIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_edit_box}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="CopyAccountIdIcon" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_page_copy}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="CustomSetting" Fill="{DynamicResource IconFillBrushAccordingTheme}" Width="20" Height="20">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_settings}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>
        <Rectangle x:Key="PinterestIcon" Fill="Red" Width="15" Height="15">
            <Rectangle.OpacityMask>
                <VisualBrush Visual="{StaticResource appbar_social_pinterest}" Stretch="Fill" />
            </Rectangle.OpacityMask>
        </Rectangle>

    </UserControl.Resources>

    <Grid Name="MainGrid" Background="Transparent">
        <Grid Panel.ZIndex="1000" Visibility="{Binding IsProgressActive,Converter={StaticResource BooleanToVisibilityConverter}}">
            <mah:ProgressRing IsActive="{Binding IsProgressActive}"  />
        </Grid>
        <Grid Panel.ZIndex="1000" Background="White" Opacity="0.1" Visibility="{Binding IsProgressActive,Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"  Name="MainContainer" Background="Transparent">

                <Border DockPanel.Dock="Left" BorderBrush="DarkGray" BorderThickness="1" Margin="5,2,20,9" Background="{DynamicResource AccentLightColorBrush}">
                   
                    <utility:TextPath  HorizontalAlignment="Center"
                               VerticalAlignment="Center" 
                               FontSize="22"
                               FontWeight="SemiBold" FontFamily="{StaticResource BuildTitleSbIt}" 
                               Fill="Black" Margin="5" Stretch="Uniform" Stroke="White" StrokeThickness="0.5"
                               Text="{DynamicResource LangKeyAccountManager}"/>

                </Border>


               
                <Border DockPanel.Dock="Right" Margin="0,2,8,9" BorderBrush="DarkGray" BorderThickness="1" Background="{DynamicResource AccentLightColorBrush}" >
                    
                    <DockPanel Name="TitleContainer" >
                        <ToggleButton DockPanel.Dock="Right" Visibility="{Binding MenuHandlerModel.IsMenuHandlerVisible,Converter={StaticResource BooleanToVisibilityConverter}}" BorderBrush="Transparent" Cursor="Hand" Background="Transparent" VerticalAlignment="Center" 
                              Name="MenuHandlerPanel" ToolTip="{DynamicResource LangKeyInfo}" Margin="10,0">
                            <ToggleButton.Template>
                                <ControlTemplate>
                                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                        <StackPanel Orientation="Horizontal" >
                                            <iconPacks:PackIconMaterial Width="25" Height="25"  Kind="ClipboardArrowDown" Foreground="Black"/>
                                            <iconPacks:PackIconMaterial Width="10" Height="15" Kind="MenuDown" Background="Transparent" Foreground="Black" Margin="5" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup DockPanel.Dock="Right" HorizontalAlignment="Right"  PopupAnimation="None" PlacementTarget="{Binding ElementName=MenuHandlerPanel}"
                               HorizontalOffset="0" VerticalOffset="5" Placement="Bottom" AllowsTransparency="True"  IsOpen="{Binding IsChecked, ElementName=MenuHandlerPanel}"  StaysOpen="False" MaxWidth="400">
                            <Border Background="{DynamicResource AccentLightColorBrush}"  CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" >
                                <WrapPanel Margin="5">
                                    <Button Background="Transparent" Visibility="{Binding MenuHandlerModel.IsImportMultipleAccountsVisible,Converter={StaticResource BooleanToVisibilityConverter}}" Cursor="Hand" BorderBrush="Transparent"  Margin="10,0,0,0" BorderThickness="0"  Name="btnLoadMultipleAccountsSub" 
                                        Command="{Binding LoadMultipleAccountsCommand}" ToolTip="{DynamicResource LangKeyImportAccountDescription}">
                                        <Button.Template>
                                            <ControlTemplate>
                                                <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                                    <StackPanel Orientation="Vertical" >
                                                        <Rectangle Width="20" Height="18" Fill="Black" >
                                                            <Rectangle.OpacityMask>
                                                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_group_add}" />
                                                                
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>
                                                        <utility:TextPath Text="{DynamicResource LangKeyImportMultipleAccounts}" Margin="5,0,0,0" Fill="Black"  Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7" >
                                                            <!--<utility:TextPath.Effect>
                                                                <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                            </utility:TextPath.Effect>-->
                                                        </utility:TextPath>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Controls:DropDownButton ArrowVisibility="Collapsed" Background="Transparent" Visibility="{Binding MenuHandlerModel.IsSelectAccountsVisible,Converter={StaticResource BooleanToVisibilityConverter}}"  Margin="10,0,0,0" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0" Name="BtnSelectSub">
                                        <Controls:DropDownButton.Content>
                                            <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                                <StackPanel Orientation="Vertical" >
                                                    <!--<Image Width="25" Height="25" Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/Select.png" />-->
                                                    <iconPacks:PackIconFontAwesome Kind="CheckCircleSolid" Foreground="Black" Width="15" HorizontalAlignment="Center" Height="15"/>
                                                    <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                                                        <utility:TextPath Text="{DynamicResource LangKeySelect}"  Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7"  >
                                                            <utility:TextPath.Effect>
                                                                <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                            </utility:TextPath.Effect>
                                                        </utility:TextPath>
                                                        <iconPacks:PackIconFontAwesome Kind="SortDownSolid" Margin="5,4,0,0" Foreground="Black" Height="10" Width="10"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Controls:DropDownButton.Content>
                                        <Controls:DropDownButton.Items>
                                            <MenuItem Header="{DynamicResource LangKeyAllAccounts}" Name="TitleMenu_AllAccountsSub"  Command="{Binding SelectAccountCommand}" CommandParameter="{StaticResource True}">

                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/selectall.png" Width="20" Height="20"/>
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <Separator />

                                            <MenuItem Header="{DynamicResource LangKeyWorkingAccounts}" Name="TitleMenuWorkingAccountsSub" Command="{Binding SelectAccountByStatusCommand}" CommandParameter="Working" >
                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/workingaccount.png" Width="20" Height="20" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <Separator />
                                            <MenuItem Header="{DynamicResource LangKeyNotWorkingAccounts}" Name="TitleMenuNotWorkingAccountSub" Command="{Binding SelectAccountByStatusCommand}" CommandParameter="NotWorking" >
                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/notworking.png" Width="20" Height="20" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Header="{DynamicResource LangKeyNotCheckedAccounts}" Name="TitleMenuNotCheckedAccountSub" Command="{Binding SelectAccountByStatusCommand}" CommandParameter="NotChecked" >
                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/NotChecked.png" Width="20" Height="20" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Name="MenuTitleGroupsSub"  Height="30" ItemsSource="{Binding Groups}" Header="{DynamicResource LangKeySelectAccountsByGroups}"  Command="{Binding UpdateGroupCommand}">
                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/groupsearch.png" />
                                                </MenuItem.Icon>
                                                <MenuItem.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Content}" IsChecked="{Binding IsContentSelected}" 
                                                        Command="{Binding DataContext.SelectAccountByGroupCommand,
                                                        RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                                        CommandParameter="{Binding}">
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </MenuItem.ItemTemplate>
                                            </MenuItem>

                                            <Separator />

                                            <MenuItem Header="{DynamicResource LangKeyDeselectAll}" Name="TitleMenu_DeselectAllSub"  Command="{Binding SelectAccountCommand}" CommandParameter="{StaticResource False}">
                                                <MenuItem.Icon>
                                                    <Image Source="/DominatorUIUtility;component/Images/deselect.png"  Width="20" Height="20"  />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                        </Controls:DropDownButton.Items>
                                    </Controls:DropDownButton>

                                    <Controls:DropDownButton  ArrowVisibility="Collapsed" Background="Transparent" Visibility="{Binding MenuHandlerModel.IsUpdateAccountVisible,Converter={StaticResource BooleanToVisibilityConverter}}"  Margin="10,0,0,0" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0" Name="btnUpdateSub">
                                        <Controls:DropDownButton.Content>
                                            <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                                <StackPanel Orientation="Vertical" >
                                                    <!--<Image Width="25" Height="25" Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/Updates.png" />-->
                                                    <iconPacks:PackIconFontAwesome Kind="RecycleSolid" Foreground="Black" HorizontalAlignment="Center" Width="15" Height="15"/>
                                                    <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                                                        <utility:TextPath Text="{DynamicResource LangKeyUpdate}" Margin="0,0,0,0" Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7" >
                                                            <!--<utility:TextPath.Effect>
                                                            <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                        </utility:TextPath.Effect>-->
                                                        </utility:TextPath>
                                                        <iconPacks:PackIconFontAwesome Kind="SortDownSolid" Margin="5,4,0,0" Foreground="Black" Height="10" Width="10"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Controls:DropDownButton.Content>
                                        <Controls:DropDownButton.Items>
                                            <MenuItem Header="{DynamicResource LangKeyUpdateAllDetails}" Name="UpdateAllDetailsMenuSub" Command="{Binding UpdateAccountDetailsCommand}" CommandParameter="UpdateAllDetail">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="13" Height="15" Fill="{DynamicResource IconFillBrushAccordingTheme}">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_refresh}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Header="{DynamicResource LangKeyCheckAccountStatus}" Name="CheckAccountStatusSub" Command="{Binding UpdateAccountDetailsCommand}" CommandParameter="CheckAccountStatus">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="{DynamicResource IconFillBrushAccordingTheme}">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_checkmark}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Header="{DynamicResource LangKeyStopProcess}" Name="StopProcessSub" Command="{Binding UpdateAccountDetailsCommand}" CommandParameter="StopProcess">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="IndianRed">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_sign_stop}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource LangKeyStopAllActivity}"  Name="StopAllActivitySub" Command="{Binding UpdateAccountDetailsCommand}" CommandParameter="StopAllActivity">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="Red">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_sign_stop}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource LangKeyUpdateAutoVerifyCredential}" Command="{Binding UpdateUserCradCommand}">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="13" Height="15" Fill="{DynamicResource IconFillBrushAccordingTheme}">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_refresh}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>



                                            <MenuItem Header="{DynamicResource LangKeySwithToBusinessAccount}" Command="{Binding SwitchToBusinessAccountCommand}" Visibility="{Binding SelectedNetworkViewModel.Selected,Converter={StaticResource SelectedNetworkToVisibilityConverter}}" CommandParameter="BusinessAccount">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="Red">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_social_pinterest}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Header="{DynamicResource LangKeySwithToNormalAccount}" Command="{Binding SwitchToBusinessAccountCommand}" Visibility="{Binding SelectedNetworkViewModel.Selected,Converter={StaticResource SelectedNetworkToVisibilityConverter}}" CommandParameter="NormalAccount">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="Red">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_social_pinterest}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </Controls:DropDownButton.Items>
                                    </Controls:DropDownButton>

                                    <Button Background="Transparent" Cursor="Hand" Visibility="{Binding MenuHandlerModel.IsExportAccountVisible,Converter={StaticResource BooleanToVisibilityConverter}}" BorderBrush="Transparent"  Margin="10,0,0,0" BorderThickness="0" Name="btnExportSub" Command="{Binding ExportCommand}">
                                        <Button.Template>
                                            <ControlTemplate>
                                                <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                                    <StackPanel Orientation="Vertical">
                                                        <Image Width="20" Height="20" Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/export.png" />

                                                        <utility:TextPath Text="{DynamicResource LangKeyExport}" Margin="5,0,0,0" Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7"  >
                                                            <!--<utility:TextPath.Effect>
                                                                <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                            </utility:TextPath.Effect>-->
                                                        </utility:TextPath>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button  Background="Transparent" Visibility="{Binding MenuHandlerModel.IsDeleteAccountVisible,Converter={StaticResource BooleanToVisibilityConverter}}" Cursor="Hand"  Margin="10,0,0,0" BorderBrush="Transparent" BorderThickness="0"  Name="btnDeleteAccountsSub" Command="{Binding DeleteAccountsCommand}">
                                        <Button.Template>
                                            <ControlTemplate>
                                                <Border HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="10" >
                                                    <StackPanel Orientation="Vertical" >
                                                        <!--<Rectangle Width="15" Height="20" Fill="IndianRed">
                                                            <Rectangle.OpacityMask>
                                                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_delete}" />
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>-->
                                                        <Image Width="20" Height="20" Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/DeleteNew.png" />
                                                        <utility:TextPath Text="{DynamicResource LangKeyDelete}" Margin="5,0,0,0" Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7"  >
                                                            <!--<utility:TextPath.Effect>
                                                                <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                            </utility:TextPath.Effect>-->
                                                        </utility:TextPath>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Controls:DropDownButton ArrowVisibility="Collapsed" MaxHeight="55" Visibility="{Binding MenuHandlerModel.IsBrowserAutomationVisible,Converter={StaticResource BooleanToVisibilityConverter}}"  Background="Transparent"  Margin="10,0,0,0" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0" Name="btnBrowserAutomationSub">
                                        <Controls:DropDownButton.Content>
                                            <Border HorizontalAlignment="Center" VerticalAlignment="Center" >
                                                <StackPanel Orientation="Vertical">
                                                    <Rectangle Fill="Black" Width="25" Height="20">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_browser_chrome}" Stretch="Fill" />
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                    <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                                                        <utility:TextPath Text="{DynamicResource LangKeyBrowserAutomation}" Margin="0,0,0,0" Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7" >
                                                            <!--<utility:TextPath.Effect>
                                                            <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
                                                        </utility:TextPath.Effect>-->
                                                        </utility:TextPath>
                                                        <iconPacks:PackIconFontAwesome Kind="SortDownSolid" Margin="5,4,0,0" Foreground="Black" Height="10" Width="10"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Controls:DropDownButton.Content>
                                        <Controls:DropDownButton.Items>
                                            <MenuItem Header="{DynamicResource LangKeyRunAllActivityThroughBrowser}" Name="btnEnableBrowserAutomationSub" Command="{Binding ActivateBrowserAutomationCommand}" CommandParameter="ActiveBrowser">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="{DynamicResource IconFillBrushAccordingTheme}">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_checkmark}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <MenuItem Header="{DynamicResource LangKeyRunAllActivityThroughHttp}" Name="btnDisableBrowserAutomationSub" Command="{Binding DeActivateBrowserAutomationCommand}" CommandParameter="DeActiveBrowser">
                                                <MenuItem.Icon>
                                                    <Rectangle Width="15" Height="15" Fill="{DynamicResource IconFillBrushAccordingTheme}">
                                                        <Rectangle.OpacityMask>
                                                            <VisualBrush Visual="{StaticResource appbar_stop}" Stretch="Fill"/>
                                                        </Rectangle.OpacityMask>
                                                    </Rectangle>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </Controls:DropDownButton.Items>
                                    </Controls:DropDownButton>


                                    <!--<Button Background="Transparent" Visibility="{Binding MenuHandlerModel.IsInfoVisible,Converter={StaticResource BooleanToVisibilityConverter}}" Name="btnInfoSub" VerticalAlignment="Center" ToolTip="{DynamicResource LangKeyInfo}" Command="{Binding InfoCommand}">
                                        <Rectangle Width="25" Height="25" Fill="White" x:Name="InfoSub"
                                            VerticalAlignment="Center" ToolTip="{DynamicResource LangKeyInfo}">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Fill" Visual="{StaticResource appbar_information_circle}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </Button>-->
                                </WrapPanel>
                            </Border>
                        </Popup>

                        <StackPanel >
                            <WrapPanel  Orientation="Horizontal" Margin="0,0,5,0" HorizontalAlignment="Left"  Background="{DynamicResource AccentLightColorBrush}">
                                <ToggleButton DockPanel.Dock="Right" Margin="10,0,0,0" Background="{DynamicResource AccentLightColorBrush}" Foreground="Transparent" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0" Name="SearchExpander">
                                    <ToggleButton.Content>
                                        <Border HorizontalAlignment="Center" Background="{DynamicResource AccentLightColorBrush}" VerticalAlignment="Center" BorderBrush="Transparent" >
                                            <StackPanel Orientation="Horizontal" >
                                                <Image Width="20" Height="20"  Stretch="UniformToFill" Source="/DominatorUIUtility;component/Images/search.ico" />
                                                <utility:TextPath Text="Search" Margin="5,0,0,0" Fill="Black" Stroke="white" FontFamily="{StaticResource BuildTitleRg}" FontSize="14.75" StrokeThickness="0.7" >
                                                    <!--<utility:TextPath.Effect>
                                                        <DropShadowEffect ShadowDepth="0.5" BlurRadius="0" Direction="0" Color="Black" />
