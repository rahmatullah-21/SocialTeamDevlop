                    </WrapPanel>
                </Grid>



            </DockPanel>
            <!--</Grid>-->

            <!--Data grid view-->
            <Grid Grid.Row="1">
                <ListView x:Name="AccountListView" ScrollViewer.IsDeferredScrollingEnabled="True"
                      VirtualizingPanel.IsContainerVirtualizable="True" Grid.Row="1"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                      AlternationCount="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Foreground="{DynamicResource AccentBaseColorBrush}">
                    <ListView.Resources>
                        <viewModel:BindingData x:Key="ContextMenuBinding" Data="{Binding}" />

                        <ContextMenu x:Key="ItemContextMenu">
                            <MenuItem Header="{DynamicResource LangKeyDetails}" CommandParameter="{Binding}"
                                  Command="{Binding Data.ProfileDetailsCommand, Source={StaticResource ContextMenuBinding}}"
                                  Icon="{DynamicResource DetailsIcon}"/>
                            <MenuItem Header="{DynamicResource LangKeyDeleteProfile}" CommandParameter="{Binding}"
                                  Command="{Binding Data.DeleteAccountCommand, Source={StaticResource ContextMenuBinding}}"
                                  Icon="{DynamicResource DeleteIcon}"/>
                            <MenuItem Header="{DynamicResource LangKeyBrowserLogin}"  Icon="{DynamicResource BrowseLoginIcon}" 
                                  CommandParameter="{Binding}"
                                  Command="{Binding Data.BrowserLoginCommand, Source={StaticResource ContextMenuBinding}}" />
                            <MenuItem Header="{DynamicResource LangKeyGoToTools}"  Icon="{DynamicResource GoToToolsIcon}"
                                  CommandParameter="{Binding}"
                                  Visibility="{Binding Data.SelectedNetworkViewModel.Selected, Source={StaticResource ContextMenuBinding}, Converter={StaticResource VisibleIfNetworkIsSocialConverter}}"
                                  Command="{Binding Data.GotoToolsCommand, Source={StaticResource ContextMenuBinding}}"/>
                            <MenuItem Header="{DynamicResource LangKeyCheckAccountStatus}" Icon="{DynamicResource CheckStatusIcon}"
                                  CommandParameter="{Binding}"
                                  Command="{Binding Data.CheckLoginCommand, Source={StaticResource ContextMenuBinding}}" />
                            <MenuItem Header="{DynamicResource LangKeyUpdateFriendship}"  Icon="{DynamicResource UpdateFriendshipIcon}"
                                  CommandParameter="{Binding}"
                                  Command="{Binding Data.UpdateFriendshipCommand, Source={StaticResource ContextMenuBinding}}" />

                            <!--<MenuItem Header="{DynamicResource LangKeyEditInstaProfile}" Visibility="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource VisibleIfNetworkIsInstagramConverter}}" 
                                  Icon="{DynamicResource InstEditIcon}" 
                                  Command="{Binding Data.EditNetworkProfileCommand, Source={StaticResource ContextMenuBinding}}"
                                  CommandParameter="{Binding}" />
                            <MenuItem Header="{DynamicResource LangKeyEditTwitterProfile}" Visibility="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource VisibleIfNetworkIsTwitterConverter}}"
                                  Icon="{DynamicResource GotoAccountProvideIcon}" CommandParameter="{Binding}"
                                  Command="{Binding Data.EditNetworkProfileCommand, Source={StaticResource ContextMenuBinding}}" />-->
                            <MenuItem Header="{DynamicResource LangKeyCopyAccountId}"  Icon="{DynamicResource CopyAccountIdIcon}"
                                  CommandParameter="{Binding}"
                                  Command="{Binding Data.CopyAccountIdCommand, Source={StaticResource ContextMenuBinding}}" />

                            <!--<MenuItem  Height="30"  Header="{DynamicResource LangKeyCustomSetting}" Icon="{DynamicResource CustomSetting}" Style="{StaticResource VisiblityStyle}" Visibility="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource VisibleIfNetworkIsNotTikTokConverter}}">-->

                                <!--<MenuItem Header="{DynamicResource LangKeySettingWizard}" CommandParameter="{Binding}"  Command="{Binding Data.SettingWizardCommand, Source={StaticResource ContextMenuBinding}}"/>-->
                                <!--<MenuItem Header="Snap Setting"  Command="{Binding Data.SnapSettingCommand, Source={StaticResource ContextMenuBinding}}"/>
                            <MenuItem Header="Copy to other Account(s)"  Command="{Binding Data.CopyToOtherAccountCommand, Source={StaticResource ContextMenuBinding}}"/>
                            <MenuItem Header="Replace on other Account(s)"  Command="{Binding Data.ReplaceOnOtherAccountCommand, Source={StaticResource ContextMenuBinding}}"/>-->
                            <!--</MenuItem>-->
                        </ContextMenu>
                    </ListView.Resources>

                    <ListView.ItemsSource>
                        <MultiBinding Converter="{StaticResource AccountsFilterConverter}" >
                            <Binding Path="LstDominatorAccountModel" IsAsync="True"/>
                            <Binding Path="SelectedNetworkViewModel.Selected"/>
                            <Binding Path="LstDominatorAccountModel.Count"/>
                        </MultiBinding>
                    </ListView.ItemsSource>

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItems}">
                            <Setter Property="Height" Value="30"/>
                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.View>
                        <GridView uiExtensions:GridViewExtension.Columns="{Binding VisibleColumns}">
                            <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <VirtualizingStackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ContentControl>
                                                <ContentControl.Style>
                                                    <Style TargetType="{x:Type ContentControl}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                            <Rectangle Margin="10,0" VerticalAlignment="Center"
                                                   Fill="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource SocialNetworkToColorBrushConverter}}"
                                                   Width="20" Height="20">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush
                                                    Visual="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource SocialNetworkToVisualBrushConverter}}"
                                                    Stretch="Fill" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <CheckBox IsChecked="{Binding IsAccountManagerAccountSelected}" Margin="10,0"
                                                  Content="{Binding (ItemsControl.AlternationIndex),
                                                  RelativeSource={RelativeSource AncestorType=ListViewItem},
                                                  Converter={StaticResource IndexToRowNoConverter}}" Foreground="{DynamicResource AccentBaseColorBrush}"/>

                                        </VirtualizingStackPanel>

                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn  Header="{DynamicResource LangKeyUsername}" DisplayMemberBinding="{Binding AccountBaseModel.UserName}"/>

                            <GridViewColumn  Header="{DynamicResource LangKeyStatus}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock >
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.InvalidCredentials}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyInvalidCredentials}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.TryingToLogin}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTryingToLogin}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.Success}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeySuccess}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.Failed}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyFailed}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.NeedsVerification}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyNeedsVerification}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.EmailVerification}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyEmailVerification}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.PhoneVerification}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyPhoneVerification}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.NotChecked}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyNotChecked}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}"  Value="{x:Static enums:AccountStatus.ProxyNotWorking}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyProxyNotWorking}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.PermanentlyBlocked}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyPermanentlyBlocked}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}"  Value="{x:Static enums:AccountStatus.TemporarilyBlocked}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTemporarilyBlocked}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}"  Value="{x:Static enums:AccountStatus.AddPhoneNumberToYourAccount}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyAddPhoneNumberToYourAccount}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}"  Value="{x:Static enums:AccountStatus.TooManyAttemptsOnPhoneVerification}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTooManyAttemptsOnPhoneVerification}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.ReTypeEmail}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyRetypeEmail}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.ReTypePhoneNumber}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyRetypePhoneNumber}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.ProfileSuspended}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyProfileSuspended}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.TwoFactorLoginAttempt}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTwoFactorLoginAttempt}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.TooManyAttemptsOnSignIn}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTooManyAttemptsOnSignIn}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.SetNewPassword}" >
                                                            <Setter Property="Text" Value="{DynamicResource LangKeySetNewPassword}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.ActionBlocked}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyActionBlock}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.DisableAccount}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyDisableAccount}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.BrowerNotSecure}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyBrowserNotsecure}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.AccountDisabled}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyAccountDisabled}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}"
                                                                 Value="{x:Static enums:AccountStatus.InvalidSecurityCode}">
                                                            <Setter Property="Text"
                                                                Value="{DynamicResource LangKeyInvalidSecurityCode}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.TooManyAttemptsWithTheSamePhoneNumber}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyTooManyAttemptWithSameNumber}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.NotRegisteredYet}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyAccountNotRegisteredYet}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccountBaseModel.Status}" Value="{x:Static enums:AccountStatus.UpdatingDetails}">
                                                            <Setter Property="Text" Value="{DynamicResource LangKeyUpdatingDetails}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn  Header="{DynamicResource LangKeyByGroupName}" DisplayMemberBinding="{Binding AccountBaseModel.AccountGroup.Content}"/>

                            <GridViewColumn  Header="{DynamicResource LangKeyProxyAddress}" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type ListViewItem}">
                                        <TextBlock Name="TextBlockName">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}:{1}">
                                                    <Binding Path="AccountBaseModel.AccountProxy.ProxyIp" />
                                                    <Binding Path="AccountBaseModel.AccountProxy.ProxyPort" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding AccountBaseModel.AccountProxy.ProxyIp}" Value="">
                                                <Setter TargetName="TextBlockName" Property="Text" Value="{DynamicResource LangKeyLocalIP}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountBaseModel.AccountProxy.ProxyIp}" Value="{x:Null}">
                                                <Setter TargetName="TextBlockName" Property="Text" Value="{DynamicResource LangKeyLocalIP}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>


                            </GridViewColumn>

                            <!--<GridViewColumn Header="{DynamicResource LangKeyBrowserAutomation}" DisplayMemberBinding="{Binding IsRunProcessThroughBrowser, Converter={StaticResource BooleanToAutomationStatusConverter}}"/>-->

                            <!--<GridViewColumn  Header="{DynamicResource LangKeyBrowserAutomation}" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type ListViewItem}">
                                        <TextBlock Name="AutomationStatus" Text="{Binding IsRunProcessThroughBrowser, Converter={StaticResource BooleanToAutomationStatusConverter}}" />

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding AccountBaseModel.AccountNetwork}" Value="{x:Static enums:SocialNetworks.Instagram}">
                                                <Setter TargetName="AutomationStatus" Property="Text" Value="NA" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>


                            </GridViewColumn>-->

                        </GridView>




                    </ListView.View>



                </ListView>
                <!--Help section-->
                <Controls:FlyoutsControl>
                    <Controls:Flyout Header="{DynamicResource LangKeyModuleDescription}" Position="Right" Visibility="Collapsed"  x:Name="HelpFlyout" FontWeight="Bold"
                                 Foreground="White"  Width="300" BorderBrush="Black" BorderThickness="2"   IsOpen="{Binding IsOpenHelpControl}"  Background="{DynamicResource AccentBaseColorBrush}" FontSize="10" >
                        <local:HelpControl ModuleDescription="{DynamicResource LangKeyAccountCustomControlDescription}"
                                                 VideoTutorial="{Binding SelectedNetworkViewModel.Selected, Converter={StaticResource SocialNetworkToLinkConverter}}" KnowledgeBaseLink="{Binding KnowledgeBaseLink}" 
                                                 ContactSupportLink="{Binding ContactSupportLink}" />
                    </Controls:Flyout>
                </Controls:FlyoutsControl>
            </Grid>


        </Grid>
    </Grid>
</UserControl>
