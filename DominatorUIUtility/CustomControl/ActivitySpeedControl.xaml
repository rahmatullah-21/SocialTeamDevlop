<UserControl x:Class="DominatorUIUtility.CustomControl.ActivitySpeedControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
 
        <StackPanel Name="MainPanel">
            <ComboBox ItemsSource="{Binding ActivitySpeed}"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Average Activities Per Day: "/>
                <TextBlock Text="{Binding AverageCountPerDay}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Average Activities Per Week: "/>
                <TextBlock Text="{Binding AverageCountPerWeek}"/>
            </StackPanel>

        </StackPanel>
            
        

</UserControl>
