<UserControl x:Class="DominatorUIUtility.ConfigControl.EmbeddedBrowserSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.ConfigControl"
             mc:Ignorable="d" 
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converter="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore">
    <UserControl.Resources>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <GroupBox Background="{DynamicResource AccentBaseColorBrush}">
        <GroupBox.Header>
            <Grid>
                <Label Content="{DynamicResource LangKeyConfiguration}" HorizontalAlignment="Left" Foreground="White"/>
                <Button Name="BtnSave" Click="BtnSave_OnClick"  Background="{DynamicResource AccentBaseColorBrush}" Foreground="White"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="15" Height="15" Fill="White">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Visual="{StaticResource appbar_save}" Stretch="Fill"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <AccessText Margin="6,0">_Save</AccessText>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </GroupBox.Header>
        <StackPanel Margin="10"  x:Name="MainGrid">
            <StackPanel Orientation="Horizontal">
                <Label Content="{DynamicResource LangKeyMaximumNumberOfSimultaneousConnections}"/>
                <controls:NumericUpDown Minimum="0" Margin="5" Value="{Binding MaxSemultaneousConnections}"/>
            </StackPanel>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyMaximizeTheEmbaddedBrowserWindowWhenTheyAreOpen}"
                      IsChecked="{Binding IsMaximizeEmbaddedBrowserChecked}"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="5" Content="{DynamicResource LangKeyWaitAMinimumOf}"
                          IsChecked="{Binding IsWaitMinOfChecked}"/>
                <controls:NumericUpDown Minimum="0" Margin="5" IsEnabled="{Binding IsWaitMinOfChecked}"
                                        Value="{Binding WaitMinOf}"/>
                <Label Content="{DynamicResource LangKeySecondsBeforeIssuingA505Error}"/>
            </StackPanel>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyForceKillEmbeddedBrowsersExperimentalUseWhenEmbeddedBrowserProcessesAreNotCorrectlyKilled}"
                      IsChecked="{Binding IsForceKillEmbeddedBrowserChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyAllowTheEmbeddedBrowserToDownloadFiles}"
                      IsChecked="{Binding IsAllowEmbeddedBrowserToDownloadFilesChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyPreventTheEmbeddedBrowserFromOpeningPopupWindow}"
                      IsChecked="{Binding IsPreventEmbeddedBrowserFromOpeningPopupChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyUseNewTextWritingSystemForFacebookExperimental}"
                      IsChecked="{Binding IsUseNewTextWritingSystemForFacebookChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyStopSavingEmbeddedBrowserScreenshotsWhenErrorOccurToSaveDiskSpace}"
                      IsChecked="{Binding IsStopSavingEmbeddedBrowserSSChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyDisableGPUAccelerationImprovesPerformanceOnMachinesWithNoDedicatedVideoCard}"
                      IsChecked="{Binding IsDisableGPUAccelerationChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyKeepALowFramerateForEmbeddedBrowserWhenNotVisibleCanImprovePerformance}"
                      IsChecked="{Binding IsKeepLowFramerateChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource LangKeyStartEmbeddedBrowserProcessesWithLowPriority}"
                      IsChecked="{Binding IsStartEmbeddedBrowserProcessesChecked}"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="5" Content="{DynamicResource LangKeyOpenAMaximumOf}"
                          IsChecked="{Binding IsOpenMaxOfChecked}"/>
                <controls:NumericUpDown Minimum="0" Margin="5" IsEnabled="{Binding IsOpenMaxOfChecked}"
                                        Value="{Binding OpenMaxOf}"/>
                <Label Content="{DynamicResource LangKeyEmbeddedBrowserAtTheSameTimeWhenUsingTheOptionFromSocialProfiles}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="5" Content="{DynamicResource LangKeyDeleteUpTo}"/>
                <controls:NumericUpDown Minimum="0" Margin="5" Value="{Binding DeleteupTo}"/>
                <Label  Margin="5" Content="{DynamicResource LangKeyKCookieCacheFilesWithEveryRestart}"/>
            </StackPanel>
            <!--<Button Content="{DynamicResource langDeleteAll}" Margin="10,0" Background="{DynamicResource AccentBaseColorBrush}" Foreground="White" HorizontalAlignment="Left"/>-->
        </StackPanel>
    </GroupBox>
</UserControl>
