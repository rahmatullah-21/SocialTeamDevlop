<UserControl x:Class="DominatorUIUtility.ConfigControl.EmbeddedBrowserSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorUIUtility.ConfigControl"
             mc:Ignorable="d" 
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converter="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore">
    <UserControl.Resources>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <GroupBox Background="{DynamicResource AccentBaseColorBrush}">
        <GroupBox.Header>
            <Grid>
                <Label Content="{DynamicResource langConfiguration}" HorizontalAlignment="Left" Foreground="White"/>
                <Button Name="BtnSave" Click="BtnSave_OnClick"  Background="{DynamicResource AccentBaseColorBrush}" Foreground="White"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="15" Height="15" Fill="White">
                                <Rectangle.OpacityMask>
                                    <VisualBrush Visual="{StaticResource appbar_save}" Stretch="Fill"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock Text="{DynamicResource langSave}" Margin="6,0"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </GroupBox.Header>
        <StackPanel Margin="10"  x:Name="MainGrid">
            <StackPanel Orientation="Horizontal">
                <Label Content="{DynamicResource DHlangMaximumNumberOfSemultaneousConnections}"/>
                <Controls:NumericUpDown Margin="5" Value="{Binding MaxSemultaneousConnections}"/>
            </StackPanel>
            <CheckBox Margin="5" Content="{DynamicResource DHlangMaximizeEmbaddedBrowser}"
                      IsChecked="{Binding IsMaximizeEmbaddedBrowserChecked}"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="5" Content="{DynamicResource DHlangWaitMinimumOf}"
                          IsChecked="{Binding IsWaitMinOfChecked}"/>
                <Controls:NumericUpDown Margin="5" IsEnabled="{Binding IsWaitMinOfChecked}"
                                        Value="{Binding WaitMinOf}"/>
                <Label Content="{DynamicResource DHlangSecondsBeforeIssuingError}"/>
            </StackPanel>
            <CheckBox Margin="5" Content="{DynamicResource DHlangForceKillEmbeddedBrowsers}"
                      IsChecked="{Binding IsForceKillEmbeddedBrowserChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangAllowEmbeddedBrowserToDownloadFiles}"
                      IsChecked="{Binding IsAllowEmbeddedBrowserToDownloadFilesChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangPreventEmbeddedBrowserFromOpeningPopup}"
                      IsChecked="{Binding IsPreventEmbeddedBrowserFromOpeningPopupChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangUseNewTextWritingSystemForFacebook}"
                      IsChecked="{Binding IsUseNewTextWritingSystemForFacebookChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangStopSavingEmbeddedBrowserScreenshots}"
                      IsChecked="{Binding IsStopSavingEmbeddedBrowserSSChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangDisableGPUAcceleration}"
                      IsChecked="{Binding IsDisableGPUAccelerationChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangKeepLowFramerate}"
                      IsChecked="{Binding IsKeepLowFramerateChecked}"/>
            <CheckBox Margin="5" Content="{DynamicResource DHlangStartEmbeddedBrowserProcesses}"
                      IsChecked="{Binding IsStartEmbeddedBrowserProcessesChecked}"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="5" Content="{DynamicResource DHlangOpenMaximumOf}"
                          IsChecked="{Binding IsOpenMaxOfChecked}"/>
                <Controls:NumericUpDown Margin="5" IsEnabled="{Binding IsOpenMaxOfChecked}"
                                        Value="{Binding OpenMaxOf}"/>
                <Label Content="{DynamicResource DHlangEmbeddedBrowserAtSameTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Margin="5" Content="{DynamicResource DHlangDeleteupTo}"/>
                <Controls:NumericUpDown Margin="5" Value="{Binding DeleteupTo}"/>
                <Label  Margin="5" Content="{DynamicResource DHlangCookieCacheFiles}"/>
            </StackPanel>
            <!--<Button Content="{DynamicResource langDeleteAll}" Margin="10,0" Background="{DynamicResource AccentBaseColorBrush}" Foreground="White" HorizontalAlignment="Left"/>-->
        </StackPanel>
    </GroupBox>
</UserControl>
