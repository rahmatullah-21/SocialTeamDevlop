<controls:MetroWindow
        x:Class="Socinator.MainWindow"
        xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dragable="http://dragablz.net/winfx/xaml/dragablz"
        xmlns:views="clr-namespace:DominatorHouse.Support.Logs.Views"
        xmlns:models="clr-namespace:DominatorHouseCore.Models;assembly=DominatorHouseCore"
        xmlns:regions="http://prismlibrary.com/"
        mc:Ignorable="d"
        Title="{Binding AvailableNetworks.Selected,StringFormat={}{0} DOMINATOR}"
        BorderThickness="1" Icon="SociNator.ico"
        WindowTitleBrush="{DynamicResource AccentColorBrush}"
        NonActiveWindowTitleBrush="#B30000"
        GlowBrush="{DynamicResource AccentColorBrush}"
        ShowIconOnTitleBar="True" 
        Name="SocinatorWindow" MinWidth="500" MinHeight="500"
        WindowState="Maximized" >

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type dragable:TabablzControl}" >
                <Setter Property="ItemContainerStyle" Value="{StaticResource TrapezoidDragableTabItemStyle}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!--Manage Networks Here -->
    <controls:MetroWindow.RightWindowCommands>
        <controls:WindowCommands>

            <ComboBox DataContext="{Binding AvailableNetworks}"  Background="Transparent" 
                      ItemsSource="{Binding ItemsCollection}" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedItem="{Binding Selected}" />
            <ComboBox DataContext="{Binding Languages}"  Background="Transparent" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedIndex="0" ItemsSource="{Binding ItemsCollection}"/>

        </controls:WindowCommands>
    </controls:MetroWindow.RightWindowCommands>
    <Grid Name="MainGrid" >
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="{Binding PerfCounterViewModel.LogViewHeight, Mode=TwoWay}"  MaxHeight="430"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Popup  StaysOpen="true" Placement="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Name="pop"
                IsOpen="{Binding IsPopUpOpen}" MouseMove="Popup_MouseMove" MouseLeftButtonDown="pop_MouseLeftButtonDown"
                MouseLeftButtonUp="pop_MouseLeftButtonUp" MouseLeave="pop_MouseLeave" MinHeight="500" MinWidth="777" 
                Height="{Binding Height}" Width="{Binding Width}" >
            <Border BorderBrush="Black" BorderThickness="1" Background="AliceBlue"  CornerRadius="10,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Background="{DynamicResource AccentBaseColorBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Image Source="SociNator.ico" Margin="5,0" Height="20" Width="20" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center"  Margin="5,0" Foreground="White">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}Socinator - {{ {0} }} ( {1} )" >
                                        <Binding Path="Network" UpdateSourceTrigger="PropertyChanged"/>
                                        <Binding Path="AccountName" UpdateSourceTrigger="PropertyChanged"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right" Grid.Column="1">
                            <Button Background="Transparent" Command="{Binding MaximizeCommand}">
                                <Button.Content>
                                    <Rectangle  Fill="White" Height="15" Width="15">
                                        <Rectangle.Style>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRestore,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" Value="False">
                                                        <Setter Property="OpacityMask">
                                                            <Setter.Value>
                                                                <VisualBrush  Stretch="Fill" Visual="{DynamicResource appbar_window_maximize}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="ToolTip" Value="Maximize"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRestore,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" Value="True">
                                                        <Setter Property="OpacityMask">
                                                            <Setter.Value>
                                                                <VisualBrush  Stretch="Fill" Visual="{DynamicResource appbar_window_restore}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="ToolTip" Value="Restore Down"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Button.Content>
                            </Button>
                            <Button Background="Transparent" Command="{Binding ModuleSettingCloseCommand}">
                                <Button.Content>
                                    <Rectangle Fill="White" Height="15" Width="15" ToolTip="{DynamicResource LangKeyClose}">
                                        <Rectangle.OpacityMask>
                                            <VisualBrush Stretch="Fill" Visual="{DynamicResource appbar_close}" />
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
                   
                    <!--<ContentControl regions:RegionManager.RegionName="StartupRegion" DataContext="{Binding}" Grid.Row="1" />-->
                </Grid>
            </Border>
        </Popup>
        <!--Account Growth Mode Tabs-->
        <TabControl Margin="5" controls:TabControlHelper.Underlined="None" TabStripPlacement="{Binding TabDock}" SelectedItem="{Binding TabItems.Selected}"
                  VerticalAlignment="Stretch" ItemsSource="{Binding TabItems.ItemsCollection}"
                    ItemContainerStyle="{StaticResource TabItemStyle}" BorderThickness="0">
            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Style.Triggers>
                        <Trigger Property="TabStripPlacement" Value="Left">
                            <Setter Property="Template" Value="{StaticResource LeftTabstyle}"></Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type  models:TabItemTemplates}">
                    <TextBlock Text="{Binding Title}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type  models:TabItemTemplates}">
                    <Grid>

                        <UserControl Content="{Binding Content.Value}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>


        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="{DynamicResource AccentBaseColorBrush}"  ResizeBehavior="BasedOnAlignment"
                      ResizeDirection="Rows" IsEnabled="{Binding IsEnabled,ElementName=statusbar}"/>

        <Grid Name="Logger" Grid.Row="2" Margin="5">
            <views:LogView MouseDoubleClick="InitialTabablzControl_MouseDoubleClick" ViewModel="{Binding LogViewModel, Mode=OneWay}"
                           AvailableNetworks="{Binding AvailableNetworks.ItemsCollection, Mode=OneWay}" x:Name="RootLayout"></views:LogView>
        </Grid>

        <Grid Grid.Row="3" VerticalAlignment="Bottom">
            <!--<views1:PerfCounterView ViewModel="{Binding PerfCounterViewModel, Mode=OneWay}" x:Name="statusbar"/>-->
            <ContentControl regions:RegionManager.RegionName="PerfCounterRegion"  x:Name="statusbar"/>
        </Grid>

    </Grid>
</controls:MetroWindow>



