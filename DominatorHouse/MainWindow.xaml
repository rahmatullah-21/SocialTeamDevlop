<Window x:Class="Socinator.MainWindow"
        xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:dragable="http://dragablz.net/winfx/xaml/dragablz"
        xmlns:views="clr-namespace:DominatorHouse.Support.Logs.Views"
        xmlns:models="clr-namespace:DominatorHouseCore.Models;assembly=DominatorHouseCore"
        xmlns:utility="clr-namespace:DominatorHouseCore.Utility;assembly=DominatorHouseCore"
        xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
        xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
        xmlns:regions="http://prismlibrary.com/"
        WindowState="Normal"
        xmlns:local="clr-namespace:Socinator"
        mc:Ignorable="d"
        MinWidth="{Binding mainViewModel.CrucialWindowModel.WindowMinimumWidth}"
        MinHeight="{Binding mainViewModel.CrucialWindowModel.WindowMinimumHeight}"
        Title="{Binding AvailableNetworks.Selected,StringFormat={}{0} DOMINATOR}"
        BorderThickness="1" Icon="SociNator.ico" Loaded="WindowLoaded"
        Name="SocinatorWindow" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Deactivated" >
            <i:InvokeCommandAction Command="{Binding WindowDeactivatedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Activated" >
            <i:InvokeCommandAction Command="{Binding WindowActivatedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="{x:Type local:MainWindow}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Window}">
                        <Border Padding="{Binding mainViewModel.CrucialWindowModel.OuterMarginSizeThickness}">
                            <Grid>

                                <Border Panel.ZIndex="10" Visibility="Collapsed"
                                    Opacity="0.3" Background="{StaticResource ForegroundVeryDarkBrush}" CornerRadius="{Binding WindowCornerRadius, FallbackValue=10}"/>

                                <!-- Opacity mask for corners on grid -->
                                <Border x:Name="Container"  Margin="0,2"
                                        Background="Red"
                                        Visibility="Visible"
                                        CornerRadius="{Binding mainViewModel.CrucialWindowModel.WindowCornerRadius, FallbackValue=10}">
                                </Border>
                                <!--Window border and dropshadown-->
                                <Border CornerRadius="{Binding mainViewModel.CrucialWindowModel.WindowCornerRadius, FallbackValue=10}"
                                         Visibility="Visible"  Margin="0,2"
                                         Background="Red">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" Opacity="0.2" />
                                    </Border.Effect>
                                </Border>
                                <!-- The main window content -->
                                <Grid>
                                    <!-- Corner clipping -->
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="OpacityMask">
                                                <Setter.Value>
                                                    <VisualBrush Visual="{Binding ElementName=Container}" />
                                                </Setter.Value>
                                            </Setter>

                                            <!--Here is the 'normal' content-->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Visibility, ElementName=Container}" Value="Collapsed">
                                                    <Setter Property="OpacityMask">
                                                        <Setter.Value>
                                                            <VisualBrush TileMode="FlipXY" >
                                                                <VisualBrush.Visual>
                                                                    <Button />
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Grid.RowDefinitions>
                                        <!-- Title Bar -->
                                        <RowDefinition Height=".176*" />
                                        <!-- Window Content -->
                                        <RowDefinition Height=".800*" />
                                        <RowDefinition Height=".024*" />
                                    </Grid.RowDefinitions>

                                    <!-- Title Bar -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <!-- Title Bar -->
                                            <RowDefinition Height=".14*" />
                                            <!-- Window Content -->
                                            <RowDefinition Height=".38*" />
                                            <RowDefinition Height=".48*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="Black" CornerRadius="10,10,0,0"/>
                                        <Border Grid.ColumnSpan="2" Grid.Row="1" Visibility="Visible">
                                            <Grid Background="{DynamicResource AccentLightColorBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.22*"/>
                                                    <ColumnDefinition Width="0.14*"/>
                                                    <ColumnDefinition Width="0.02*"/>
                                                    <ColumnDefinition Width="0.37*"/>
                                                    <ColumnDefinition Width="0.14*"/>
                                                    <ColumnDefinition Width="0.11*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Margin="10,5,-20,5">
                                                    <Image VerticalAlignment="Center" Stretch="Fill"  Source="Images/CrucialConnectionImage.jpg"/>
                                                </Grid>
                                                
                                                <Grid Grid.Column="1">
                                                    <Grid.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="5" Color="Black"/>
                                                    </Grid.Effect>
                                                    <ComboBox Style="{StaticResource ComboBoxStyle}" FontFamily="{StaticResource BuildTitleSbIt}" FontWeight="Light" DataContext="{Binding AvailableNetworks}" FontSize="30"  Background="Transparent" 
                                                    ItemsSource="{Binding ItemsCollection}" SelectedItem="{Binding Selected}"/>
                                                </Grid>
                                                
                                                <Grid Grid.Column="4" HorizontalAlignment="Right" Margin="0,0,15,0">
                                                    <Grid.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="5" Color="Black"/>
                                                    </Grid.Effect>
                                                    <ComboBox Style="{StaticResource ComboBoxStyle}" FontFamily="{StaticResource BuildTitleSbIt}" FontWeight="Light" HorizontalAlignment="Center" FontSize="30" DataContext="{Binding Languages}" BorderThickness="0" SelectedIndex="0" ItemsSource="{Binding ItemsCollection}"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,2,0" Grid.Column="5" >
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button HorizontalAlignment="Right" Command="{Binding CloseCommand}" Height="28" Width="28">
                                                        <Button.Background>
                                                            <ImageBrush ImageSource="Images/macos_buttons1.ico"/>
                                                        </Button.Background>
                                                    </Button>
                                                    <Button Command="{Binding MinimizeCommand}" Grid.Column="1"  Height="25" Width="25">
                                                        <Button.Background>
                                                            <ImageBrush ImageSource="Images/macos_buttons2.ico"/>
                                                        </Button.Background>
                                                    </Button>
                                                    <Button HorizontalAlignment="Left" Command="{Binding MaximizeCommand}"  Grid.Column="2" Height="25" Width="25">
                                                        <Button.Background>
                                                            <ImageBrush ImageSource="Images/macos_buttons3.ico"/>
                                                        </Button.Background>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource AccentColorBrush}">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="2" Direction="290"  BlurRadius="5" Color="Gray"/>
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                    
                                    <!-- Page Content -->
                                    <Border Grid.Row="1" ClipToBounds="True">
                                        <ContentPresenter Content="{TemplateBinding Content}" />
                                    </Border>

                                    <Border Grid.Row="2" Background="Black" CornerRadius="0,0,10,10"/>
                                </Grid>

                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome
            ResizeBorderThickness="{Binding mainViewModel.CrucialWindowModel.ResizeBorderThickness}"
            CaptionHeight="10"
            CornerRadius="0"
            GlassFrameThickness="0"/>

    </WindowChrome.WindowChrome>
    <Border>
        <Border.Background>
            <ImageBrush ImageSource="Images/crucial-background.png" Stretch="UniformToFill"/>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                 <!--Title Bar--> 
                <RowDefinition Height="0.15*" />
                <RowDefinition Height="0.85*" />
                 <!--Window Content--> 
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                
            </Grid.RowDefinitions>


            <Border Grid.Row="1" Background="Transparent"  Margin="40,0,40,25" Padding="{Binding InnerPadding}" CornerRadius="5">
                <TabControl Grid.Row="1" Margin="5"  controls:TabControlHelper.Underlined="None" TabStripPlacement="{Binding TabDock}" SelectedItem="{Binding TabItems.Selected}"
                  VerticalAlignment="Stretch" ItemsSource="{Binding TabItems.ItemsCollection}"
                    Foreground="Black" BorderThickness="0">
                    <TabControl.Style>
                        <Style TargetType="TabControl">
                            <Style.Triggers>
                                <Trigger Property="TabStripPlacement" Value="Left">
                                    <Setter Property="Template" Value="{DynamicResource LeftTabstyle1}"></Setter>
                                    <Setter Property="ItemContainerStyle" Value="{DynamicResource LeftTabItemStyle}"/>
                                    <Setter Property="ItemTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <utility:TextPath Text="{Binding Title}"   HorizontalAlignment="Center"
		                                        VerticalAlignment="Center"
		                                        Fill="Black"
		                                        Stroke="White"                                             
		                                        FontFamily="{StaticResource BuildTitleBdIt}"
		                                        FontSize="16"
                                                FontWeight="Bold">
                                                </utility:TextPath>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="TabStripPlacement" Value="Top">
                                    <Setter Property="Template" Value="{DynamicResource TopTabstyle}"></Setter>
                                    <Setter Property="ItemContainerStyle" Value="{DynamicResource TabItemStyle}"/>
                                    <Setter Property="ItemTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <utility:TextPath Text="{Binding Title}"   HorizontalAlignment="Center"
		                                            VerticalAlignment="Center"
		                                            Fill="#ffffff"
                                                    StrokeThickness="1"
                                                    StrokeMiterLimit="1"
		                                            Stroke="Black"
                                                    FontStyle="Italic"
		                                            FontFamily="{StaticResource BuildTitleBdIt}"
		                                            FontSize="19"
                                                    FontWeight="Bold">
                                                    <utility:TextPath.Effect>
                                                        <DropShadowEffect BlurRadius="0" ShadowDepth="3" Direction="360" Color="Black" ></DropShadowEffect>
                                                    </utility:TextPath.Effect>
                                                </utility:TextPath>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Style>
                    <!--<TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type  models:TabItemTemplates}">
                            <utility:TextPath Text="{Binding Title}"   HorizontalAlignment="Center"
		                VerticalAlignment="Center"
		                Fill="White"
		                Stroke="Black"
		                StrokeThickness="1"
                        StrokeMiterLimit="1"                                              
		                FontFamily="{StaticResource  BuildTitleSbIt}"
                        FontStyle="Italic"
		                FontSize="19"
                        FontWeight="Bold">
                                <utility:TextPath.Effect>
                                    <DropShadowEffect BlurRadius="0" ShadowDepth="3" Direction="360" Color="Black" ></DropShadowEffect>
                                </utility:TextPath.Effect>
                            </utility:TextPath>
                        </DataTemplate>
                    </TabControl.ItemTemplate>-->
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type  models:TabItemTemplates}">
                            <Grid>
                                <UserControl Content="{Binding Content.Value}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Border>


            <GridSplitter Grid.Row="2" Height="2" HorizontalAlignment="Stretch" Background="Red"  ResizeBehavior="BasedOnAlignment"
                      ResizeDirection="Rows" IsEnabled="{Binding IsEnabled,ElementName=statusbar}"/>

            <Grid Visibility="Collapsed" Name="Logger" Grid.Row="3" Margin="5">
                <views:LogView MouseDoubleClick="InitialTabablzControl_MouseDoubleClick" ViewModel="{Binding LogViewModel, Mode=OneWay}"
                           AvailableAccounts="{Binding AccountList, Mode=OneWay}"
                           AvailableNetworks="{Binding AvailableNetworks.ItemsCollection, Mode=OneWay}" x:Name="RootLayout"></views:LogView>
            </Grid>

            <!--<Grid Grid.Row="3" VerticalAlignment="Bottom">
                <views1:PerfCounterView ViewModel="{Binding PerfCounterViewModel, Mode=OneWay}" x:Name="statusbar"/>
                <ContentControl regions:RegionManager.RegionName="PerfCounterRegion"  x:Name="statusbar"/>
            </Grid>-->

        </Grid>
        
    </Border>
</Window>