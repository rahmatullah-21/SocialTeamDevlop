<controls:MetroWindow
        x:Class="Socinator.MainWindow"
        xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dockable="http://dragablz.net/winfx/xaml/dockablz"
        xmlns:dragable="http://dragablz.net/winfx/xaml/dragablz"
        mc:Ignorable="d"
        BorderThickness="1" Icon="SociNator.ico"
        Title="{DynamicResource LangKeySocinator}" 
        WindowTitleBrush="{DynamicResource AccentColorBrush}"
        NonActiveWindowTitleBrush="#B30000"
        GlowBrush="{DynamicResource AccentColorBrush}"
        ShowIconOnTitleBar="True" 
        Name="SocinatorWindow"
        WindowState="Maximized" 
        xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
        xmlns:behaviour="clr-namespace:DominatorUIUtility.Behaviours;assembly=DominatorUIUtility"
        xmlns:cmd="clr-namespace:GalaSoft.MvvmLight.Command;assembly=GalaSoft.MvvmLight.Platform">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <cmd:EventToCommand Command="{Binding Path=WinClosingCommand}" PassEventArgsToCommand="True" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type dragable:TabablzControl}" x:Key="TabablzControlStyle">
                <Setter Property="ItemContainerStyle" Value="{StaticResource TrapezoidDragableTabItemStyle}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <!--Manage Networks Here -->
    <controls:MetroWindow.RightWindowCommands>
        <controls:WindowCommands>
            <ComboBox Background="Transparent" ItemsSource="{Binding MainWindowModel.AvailableNetworks}" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedIndex="{Binding MainWindowModel.SelectedNetworkIndex}" Name="cmbSocialNetwork"
                      behaviour:SelectionChangedBehaviour.Command="{Binding NetworkChangeCommand}"/>
            <ComboBox Background="Transparent" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedIndex="0" 
                      Name="cmbLanguage" ItemsSource="{Binding MainWindowModel.Languages}"
                      behaviour:SelectionChangedBehaviour.Command="{Binding LanguageChangeCommand}"/>
           
        </controls:WindowCommands>
    </controls:MetroWindow.RightWindowCommands>
    <Grid Name="MainGrid" >
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="3*"  MaxHeight="600"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <TabControl Margin="5" controls:TabControlHelper.Underlined="None" TabStripPlacement="{Binding MainWindowModel.TabDock}" SelectedIndex="{Binding MainWindowModel.SelectedViewIndex}"
                   Name="MainTabControl" VerticalAlignment="Stretch" ItemsSource="{Binding MainWindowModel.TabItems}"
                    ItemContainerStyle="{StaticResource TabItemStyle}" SelectedItem="{Binding MainWindowModel.SelectedContent}">

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" Visibility="{Binding Visible}" Name="TabHeader">
                         <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding DataContext.TabItemSelectCommand,RelativeSource={RelativeSource AncestorType=TabControl}}" CommandParameter="{Binding ElementName=TabHeader}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBlock>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <UserControl Content="{Binding Content.Value}" Visibility="{Binding Visible}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="{DynamicResource AccentBaseColorBrush}"  ResizeBehavior="BasedOnAlignment"
                      ResizeDirection="Rows" />

        <Grid Name="Logger" Grid.Row="2" Margin="5">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Top" 
                       Margin="0,0,15,0">

                <Label Content="{DynamicResource LangKeyFilterByNetwork}" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding MainWindowModel.AvailableNetworks}" Width="200" SelectedIndex="-1" Name="CmbAvailableNetworks"
                          controls:TextBoxHelper.ClearTextButton="True" SelectedItem="{Binding MainWindowModel.SelectedNetwork}"
                          behaviour:SelectionChangedBehaviour.Command="{Binding LoggerNetworkChangeCommand}"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=CmbAvailableNetworks,Path=SelectedIndex}" Value="-1">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Label Content="{DynamicResource LangKeyFilterByActivityType}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding MainWindowModel.ActivityType}" Width="200" controls:TextBoxHelper.ClearTextButton="True"
                              Name="CmbActivityType" SelectedItem="{Binding MainWindowModel.SelectedActivity}"
                              behaviour:SelectionChangedBehaviour.Command="{Binding LoggerActivityChangeCommand}"/>
                </StackPanel>
            </StackPanel>

            <dockable:Layout  Name="RootLayout" >
                <dragable:TabablzControl x:Name="InitialTabablzControl"  Style="{StaticResource TabablzControlStyle}" Margin="0,5,0,0"
                                         MouseDoubleClick="InitialTabablzControl_MouseDoubleClick" SelectedItem="{Binding MainWindowModel.SelectedLogTab}"
                                         behaviour:SelectionChangedBehaviour.Command="{Binding LoggerSelectionChangeCommand}">

                    <TabItem Header="Info" Name="InfoTab" >
                        <ListView x:Name="InfoLogger" ItemsSource="{Binding MainWindowModel.LoggerCollection,IsAsync=True}">
                            <ListView.CommandBindings>
                                <CommandBinding Command="ApplicationCommands.Copy" CanExecute="CopyCanExecute" Executed="CopyExecuted" />
                            </ListView.CommandBindings>
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <GridViewColumn  Width="50" >
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Rectangle Height="15" Width="15" >
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LogType}" Value="Info">
                                                                        <Setter Property="OpacityMask">
                                                                            <Setter.Value>
                                                                                <VisualBrush Visual="{StaticResource appbar_information_circle}" Stretch="Fill" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="Fill">
                                                                            <Setter.Value>
                                                                                <SolidColorBrush Color="LimeGreen"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="ToolTip" Value="{DynamicResource LangKeyInformations}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource LangKeyDatetime}" DisplayMemberBinding="{Binding DateTime}" Width="150" />
                                        <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" DisplayMemberBinding="{Binding Network}" Width="130"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyAccountCampaignName}" DisplayMemberBinding="{Binding AccountCampaign}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyActivityType}" DisplayMemberBinding="{Binding ActivityType}" Width="130"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyMessage}" DisplayMemberBinding="{Binding Message}" Width="680"/>
                                    </GridView.Columns>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>
                    <TabItem Header="Error List" Name="ErrorTab" >
                        <ListView x:Name="ErrorLogger" ItemsSource="{Binding MainWindowModel.LoggerCollection,IsAsync=True}">
                            <ListView.CommandBindings>
                                <CommandBinding Command="ApplicationCommands.Copy"
                                                CanExecute="CopyCanExecute" Executed="CopyExecuted" />
                            </ListView.CommandBindings>
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <GridViewColumn  Width="50" >
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Rectangle Height="15" Width="15" >
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LogType}" Value="Error">
                                                                        <Setter Property="OpacityMask">
                                                                            <Setter.Value>
                                                                                <VisualBrush Visual="{StaticResource appbar_stop}" Stretch="Fill" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="Fill">
                                                                            <Setter.Value>
                                                                                <SolidColorBrush Color="Red"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="ToolTip" Value="{DynamicResource LangKeyError}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding LogType}" Value="Warn">
                                                                        <Setter Property="OpacityMask">
                                                                            <Setter.Value>
                                                                                <VisualBrush Visual="{StaticResource appbar_shield_alert}" Stretch="Fill"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="Fill">
                                                                            <Setter.Value>
                                                                                <SolidColorBrush Color="#ffd700"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="ToolTip" Value="{DynamicResource LangKeyWarning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource LangKeyDatetime}" DisplayMemberBinding="{Binding DateTime}" Width="150"/>
                                        <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" DisplayMemberBinding="{Binding Network}" Width="130"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyAccountCampaignName}" DisplayMemberBinding="{Binding AccountCampaign}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyActivityType}" DisplayMemberBinding="{Binding ActivityType}" Width="130"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyMessage}" DisplayMemberBinding="{Binding Message}" Width="680"/>
                                    </GridView.Columns>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <!--<ListBox x:Name="ErrorLogger"/>-->
                    </TabItem>

                </dragable:TabablzControl>
            </dockable:Layout>

        </Grid>

        <Grid Grid.Row="3" VerticalAlignment="Bottom">
            <StatusBar Background="{DynamicResource AccentColorBrush}" Height="25" VerticalAlignment="Center" >
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem  Grid.Column="4" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyLoadedMemory}" Foreground="White" />
                        <TextBlock  Text="{Binding MainWindowModel.RamSize}" Foreground="White"/>
                    </StackPanel>

                </StatusBarItem>

                <StatusBarItem  Grid.Column="1" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyAvailableMemory}" Foreground="White"/>
                        <TextBlock  Text="{Binding  MainWindowModel.Availablememory}" Foreground="White" />
                    </StackPanel>

                </StatusBarItem>
                <StatusBarItem  Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource LangKeyActivityLog}" Name="ActivityLog" >
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding ResizeLoggerCommand}" CommandParameter="{Binding ElementName=MainGrid}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBlock>
                </StatusBarItem>

                <StatusBarItem  Grid.Column="3" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyCPUUsage}" Foreground="White" />
                        <TextBlock Text="{Binding  MainWindowModel.CpuUsage}" Foreground="White" />
                    </StackPanel>

                </StatusBarItem>
                <StatusBarItem  Grid.Column="0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyDate}" Foreground="White" />
                        <TextBlock Text="{Binding  MainWindowModel.Datetime}"  Foreground="White"  />
                    </StackPanel>

                </StatusBarItem>
            </StatusBar>

        </Grid>

    </Grid>
</controls:MetroWindow>



