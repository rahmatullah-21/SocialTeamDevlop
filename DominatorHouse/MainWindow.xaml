<controls:MetroWindow
        x:Class="Socinator.MainWindow"
        xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dockable="http://dragablz.net/winfx/xaml/dockablz"
        xmlns:dragable="http://dragablz.net/winfx/xaml/dragablz"
        mc:Ignorable="d"
        BorderThickness="1" Icon="Images/SociNator.ico"
        Title="{DynamicResource LangKeySocinator}" 
        WindowTitleBrush="{DynamicResource AccentColorBrush}"
        NonActiveWindowTitleBrush="#B30000"
        GlowBrush="{DynamicResource AccentColorBrush}"
        ShowIconOnTitleBar="True" 
    Name="SocinatorWindow"
    WindowState="Maximized" 
    Closing="SocinatorWindow_OnClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type dragable:TabablzControl}" x:Key="TabablzControlStyle">
                <Setter Property="ItemContainerStyle" Value="{StaticResource TrapezoidDragableTabItemStyle}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <!--Manage Networks Here -->
    <controls:MetroWindow.RightWindowCommands>
        <controls:WindowCommands>
            <ComboBox Background="Transparent" ItemsSource="{Binding AvailableNetworks}" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedNetworkIndex}" Name="cmbSocialNetwork" SelectionChanged="cmbSocialNetwork_SelectionChanged" />
            <ComboBox Background="Transparent" Foreground="White" BorderBrush="Transparent" BorderThickness="0" SelectedIndex="0" 
                      Name="cmbLanguage" ItemsSource="{Binding Languages}"/>
            <!--<ComboBoxItem>English</ComboBoxItem>
                -->
            <!--<ComboBoxItem>Portuguese</ComboBoxItem>-->
            <!--
            </ComboBox>-->
        </controls:WindowCommands>
    </controls:MetroWindow.RightWindowCommands>
    <Grid Name="MainGrid" >

        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!--Account Growth Mode Tabs-->
        <TabControl Margin="5" controls:TabControlHelper.Underlined="None" TabStripPlacement="{Binding TabDock}" SelectedIndex="{Binding SelectedViewIndex}"
                   Name="MainTabControl" VerticalAlignment="Stretch" ItemsSource="{Binding TabItems}"
                    ItemContainerStyle="{StaticResource TabItemStyle}">


            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" MouseLeftButtonDown="TabItem_OnMouseLeftButtonDown"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <UserControl Content="{Binding Content.Value}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="{DynamicResource AccentBaseColorBrush}"  ResizeBehavior="BasedOnAlignment"
                      ResizeDirection="Rows"/>

        <Grid Name="Logger" Grid.Row="2" Margin="5">
      
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Top" 
                       Margin="0,0,15,0">
               
                <Label Content="{DynamicResource LangKeyFilterByNetwork}" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding AvailableNetworks}" Width="200" SelectedIndex="-1" Name="CmbAvailableNetworks"
                          controls:TextBoxHelper.ClearTextButton="True"
                          SelectionChanged="CmbAvailableNetworks_OnSelectionChanged"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=CmbAvailableNetworks,Path=SelectedIndex}" Value="-1">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Label Content="{DynamicResource LangKeyFilterByActivityType}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding ActivityType}" Width="200" controls:TextBoxHelper.ClearTextButton="True"
                              Name="CmbActivityType"
                              SelectionChanged="CmbActivityType_OnSelectionChanged"/>
                </StackPanel>
            </StackPanel>

            <dockable:Layout  Name="RootLayout" >
                <dragable:TabablzControl x:Name="InitialTabablzControl"  Style="{StaticResource TabablzControlStyle}" Margin="0,5,0,0"
                                         MouseDoubleClick="InitialTabablzControl_MouseDoubleClick" 
                                         SelectionChanged="InitialTabablzControl_OnSelectionChanged">
                    <TabItem Header="Info" Name="InfoTab" >
                        <ListView x:Name="InfoLogger" ItemsSource="{Binding LoggerCollection}">
                            <ListView.CommandBindings>
                                <CommandBinding Command="ApplicationCommands.Copy"
                                                CanExecute="CopyCanExecute" Executed="CopyExecuted" />
                            </ListView.CommandBindings>
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <GridViewColumn Header="{DynamicResource LangKeyDatetime}" DisplayMemberBinding="{Binding DateTime}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" DisplayMemberBinding="{Binding Network}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyAccountName}" DisplayMemberBinding="{Binding Account}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyActivityType}" DisplayMemberBinding="{Binding ActivityType}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyMessage}" DisplayMemberBinding="{Binding Message}"/>
                                    </GridView.Columns>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <!--<ListBox x:Name="InfoLogger" IsSelected="True"/>-->
                    </TabItem>
                    <TabItem Header="Error List" Name="ErrorTab" >
                        <ListView x:Name="ErrorLogger" ItemsSource="{Binding LoggerCollection}">
                            <ListView.CommandBindings>
                                <CommandBinding Command="ApplicationCommands.Copy"
                                                CanExecute="CopyCanExecute" Executed="CopyExecuted" />
                            </ListView.CommandBindings>
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <GridViewColumn Header="{DynamicResource LangKeyDatetime}" DisplayMemberBinding="{Binding DateTime}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeySocialNetwork}" DisplayMemberBinding="{Binding Network}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyAccountName}" DisplayMemberBinding="{Binding Account}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyActivityType}" DisplayMemberBinding="{Binding ActivityType}"/>
                                        <GridViewColumn Header="{DynamicResource LangKeyMessage}" DisplayMemberBinding="{Binding Message}"/>
                                    </GridView.Columns>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <!--<ListBox x:Name="ErrorLogger"/>-->
                    </TabItem>

                </dragable:TabablzControl>
            </dockable:Layout>
     
        </Grid>

        <Grid Grid.Row="3" VerticalAlignment="Bottom">
            <StatusBar Background="{DynamicResource AccentColorBrush}" Height="25" VerticalAlignment="Center" >
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem  Grid.Column="0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyLoadedMemory}"
                               Foreground="White" />
                        <TextBlock Name="lbl_LoadedMemory" Text="{DynamicResource LangKey0MB}"
                           Foreground="White"/>
                    </StackPanel>

                </StatusBarItem>

                <StatusBarItem  Grid.Column="1" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LangKeyAvailableMemory}" Foreground="White"/>
                        <TextBlock Name="lbl_Availablememory"  Text="{DynamicResource LangKey0MB}"
                   Foreground="White" />
                    </StackPanel>

                </StatusBarItem>
                <StatusBarItem  Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource LangKeyActivityLog}" Name="ActivityLog" MouseDown="ActivityLog_OnMouseDown"/>
                </StatusBarItem>

                <StatusBarItem  Grid.Column="3" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="{DynamicResource LangKeyCPUUsage}"
                               Foreground="White" />
                        <TextBlock Name="lbl_CPUUsage" Text=" 0% " Foreground="White" />
                    </StackPanel>

                </StatusBarItem>
                <StatusBarItem  Grid.Column="4" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock    Text="{DynamicResource LangKeyDate}" Foreground="White" />
                        <TextBlock Name="lbl_Datetime" Text="{Binding Source={x:Static sys:DateTime.Now}}"  Foreground="White"  />
                    </StackPanel>

                </StatusBarItem>
            </StatusBar>

        </Grid>

    </Grid>
</controls:MetroWindow>



