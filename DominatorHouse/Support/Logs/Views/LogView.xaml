<UserControl x:Class="DominatorHouse.Support.Logs.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dragablz="http://dragablz.net/winfx/xaml/dragablz"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
             xmlns:views="clr-namespace:DominatorHouse.Support.Logs.Views"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:viewModel="clr-namespace:DominatorHouseCore.ViewModel;assembly=DominatorHouseCore"
             xmlns:models="clr-namespace:DominatorHouseCore.Models;assembly=DominatorHouseCore"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <system:Boolean x:Key="True">True</system:Boolean>
        <converters:AccountsFilterConverter x:Key="AccountsFilterConverter"/>
        <converters:ActivityTypesSourceConverter x:Key="ActivityTypesSourceConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"></BooleanToVisibilityConverter>
        <converters:SocialNetworkToColorBrushConverter x:Key="SocialNetworkToColorBrushConverter" />
        <converters:SocialNetworkToVisualBrushConverter x:Key="SocialNetworkToVisualBrushConverter" />
    </UserControl.Resources>
    <UserControl.Template>
        <ControlTemplate>
            <Grid DataContext="{Binding (views:LogView.ViewModel), RelativeSource={RelativeSource TemplatedParent}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Top" 
                            Margin="0,0,15,0">

                    <Label Content="{DynamicResource LangKeyFilterByNetwork}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding (views:LogView.AvailableNetworks), RelativeSource={RelativeSource TemplatedParent}}" Width="200"
                              mah:TextBoxHelper.ClearTextButton="True" SelectedItem="{Binding (viewModel:LogViewModel.SelectedNetwork), Mode=TwoWay}"/>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding (viewModel:LogViewModel.NetworkIsSelected), Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Label Content="{DynamicResource LangKeyFilterByActivityType}" FontWeight="SemiBold"/>
                        <ComboBox Width="200" mah:TextBoxHelper.ClearTextButton="True"
                                  Name="CmbActivityType" SelectedItem="{Binding (viewModel:LogViewModel.ActivityTypes).Selected}">
                            <ComboBox.ItemsSource>
                                <MultiBinding Converter="{StaticResource ActivityTypesSourceConverter}">
                                    <Binding Path="(viewModel:LogViewModel.ActivityTypes).ItemsCollection"></Binding>
                                    <Binding Path="(viewModel:LogViewModel.SelectedNetwork)"></Binding>
                                </MultiBinding>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Label Content="{DynamicResource LangKeyFilterByAccount}" FontWeight="SemiBold"/>
                        <ComboBox Width="200" mah:TextBoxHelper.ClearTextButton="True"
                                  Name="CmbAccount" SelectedItem="{Binding (viewModel:LogViewModel.SelectedAccount), Mode=TwoWay}">
                            <ComboBox.ItemsSource>
                                <MultiBinding Converter="{StaticResource AccountsFilterConverter}" ConverterParameter="{StaticResource True}">
                                    <Binding Path="(views:LogView.AvailableAccounts)"  RelativeSource="{RelativeSource TemplatedParent}" IsAsync="True"/>
                                    <Binding Path="(viewModel:LogViewModel.SelectedNetwork)" />
                                </MultiBinding>
                            </ComboBox.ItemsSource>
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DominatorAccountModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Margin="5,0" VerticalAlignment="Center"
                                                   Fill="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource SocialNetworkToColorBrushConverter}}"
                                                   Width="12" Height="12">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush
                                                    Visual="{Binding AccountBaseModel.AccountNetwork, Converter={StaticResource SocialNetworkToVisualBrushConverter}}"
                                                    Stretch="Fill" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock Text="{Binding AccountBaseModel.UserName}" FontWeight="SemiBold" Foreground="{DynamicResource TextColorBrushAccordingTheme}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
                <dragablz:TabablzControl x:Name="InitialTabablzControl" SelectionChanged="TabSelectionChange"
                                             Style="{DynamicResource TabablzControlStyle}" Margin="0,5,0,0" >
                    <TabItem Header="{DynamicResource LangKeyInfo}" Name="InfoTab" IsSelected="True" >
                        <views:LogList Logs="{Binding (viewModel:LogViewModel.Logs)}" 
                                           NetworkFilter="{Binding (viewModel:LogViewModel.SelectedNetwork)}" 
                                           ActivityTypeFilter="{Binding (viewModel:LogViewModel.ActivityTypes).Selected}" 
                                           LogTypeFilter="{x:Static views:LogList.LogTypeInfo}"
                                           SelectedLoggerModel="{Binding (viewModel:LogViewModel.Selected), Mode=TwoWay}"
                                           SyncObject="{Binding (viewModel:LogViewModel.SyncObject), Mode=OneTime}"/>
                    </TabItem>
                    <TabItem Header="{DynamicResource LangKeyError}" Name="ErrorTab" >
                        <views:LogList Logs="{Binding (viewModel:LogViewModel.Logs)}" 
                                           NetworkFilter="{Binding (viewModel:LogViewModel.SelectedNetwork)}" 
                                           ActivityTypeFilter="{Binding (viewModel:LogViewModel.ActivityTypes).Selected}" 
                                           LogTypeFilter="{x:Static views:LogList.LogTypeError}"
                                           SelectedLoggerModel="{Binding (viewModel:LogViewModel.Selected), Mode=TwoWay}"
                                           SyncObject="{Binding (viewModel:LogViewModel.SyncObject), Mode=OneTime}"/>
                    </TabItem>
                </dragablz:TabablzControl>
            </Grid>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
