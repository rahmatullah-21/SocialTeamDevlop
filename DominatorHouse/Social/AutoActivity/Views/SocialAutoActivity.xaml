<UserControl x:Class="DominatorHouse.Social.AutoActivity.Views.SocialAutoActivity"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DominatorHouse.Social.AutoActivity.Views"
             mc:Ignorable="d" Name="SocialActivity"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="5">
            <Button Width="100" Height="30" Content="Instagram" Foreground="Black" Click="ClickButton_OnClick" />

            <Button Width="100" Margin="5" Height="30" Content="twitter" Foreground="Black" Click="ButtonBase1_OnClick" />
        </StackPanel>
    </Grid>
</UserControl>
