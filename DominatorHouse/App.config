<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
  </configSections>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6" />
  </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.0" newVersion="10.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="PresentationFramework" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.0.0" newVersion="4.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="protobuf-net" publicKeyToken="257b51d87d2e4d67" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2.3.6.0" newVersion="2.3.6.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="HtmlAgilityPack" publicKeyToken="bd319b19eaf3b43a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-1.7.1.0" newVersion="1.7.1.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="FluentScheduler" publicKeyToken="b76503528a14ebd1" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.3.0.0" newVersion="5.3.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="v13.0" />
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SQLite.EF6" type="System.Data.SQLite.EF6.SQLiteProviderServices, System.Data.SQLite.EF6" />
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
      <provider invariantName="System.Data.SQLite" type="System.Data.SQLite.EF6.SQLiteProviderServices, System.Data.SQLite.EF6" />
    </providers>
  </entityFramework>
  <system.data>
    <DbProviderFactories>
      <remove invariant="System.Data.SQLite.EF6" />
      <add name="SQLite Data Provider (Entity Framework 6)" invariant="System.Data.SQLite.EF6" description=".NET Framework Data Provider for SQLite (Entity Framework 6)" type="System.Data.SQLite.EF6.SQLiteProviderFactory, System.Data.SQLite.EF6" />
      <remove invariant="System.Data.SQLite" />
      <add name="SQLite Data Provider" invariant="System.Data.SQLite" description=".NET Framework Data Provider for SQLite" type="System.Data.SQLite.SQLiteFactory, System.Data.SQLite" />
    </DbProviderFactories>
  </system.data>
  
  <appSettings>
    
    <add key="AesKey" value="3sc3RLrpd17" />
    <add key="Social" value="Socinator" />    
    <add key="Facebook" value="FaceDominatorUI" />
    <add key="Twitter" value="TwtDominatorUI" />
    <add key="Gplus" value="GplusDominatorUI" />
    <add key="Instagram" value="GramDominatorUI" />
    <add key="LinkedIn" value="LinkedDominatorUI" />
    <add key="Quora" value="QuoraDominatorUI" />
    <add key="Pinterest" value="PinDominator" />
    <add key="Tumblr" value="TumblrDominatorUI" />
    <add key="Youtube" value="YoutubeDominatorUI" />
    <add key="Reddit" value="RedditDominatorUI" />
    
    <!--Begins Exemption-->

    <add key="ExceptionKey" value="4A8Re6saPmIlEnEpzT3Z" />
    <add key="Unavailable" value="no_activation_found" />   
    <add key="EmptyExemption" value="license_empty" />    
    <add key="EmptyExemptionErrorMessage" value="Empty or invalid license key submitted, Please check your license key and enter again." />   
    <add key="ExemptionNotFound" value="license_not_found" />
    <add key="ExemptionNotFoundErrorMessage" value="Oops, we are unable to find key you have entered, please recheck once at your end or contact support." />
    <add key="ExemptionDisabled" value="license_disabled" />
    <add key="ExemptionDisabledErrorMessage" value="Your License key has been disabled, please contact support for more information." />
    <add key="ExemptionExpired" value="license_expired" />
    <add key="FatalExcemptionExpired" value="Expired" />
    <add key="ExemptionExpiredErrorMessage" value="Your license key has got expired, please renew your subscription or contact support." />
    <add key="InvalidInput" value="invalid_input" />
    <add key="Invalid" value="Invalid" />
    <add key="InvalidInputErrorMessage" value="Your entered license key is invalid, please check your license key and enter again." />
    <add key="MoreLimits" value="no_spare_activations" />
    <add key="MoreLimitsErrorMessage" value="You have already reached the maximum allowed activations for this license key, please buy more license or deactivate your previous activation." />
    <add key="NoMoreAllowed" value="no_reactivation_allowed" />
    <add key="NoMoreAllowedErrorMessage" value="Sorry, but we are unable to reactivate your license key, please contact support." />
    <add key="Matched" value="ok" />
    <add key="Uniform" value="Active" />
    <add key="Fluent" value="Suspended" /> 
    <add key="Unknown" value="other_error" />
    <add key="UnknownErrorMessage" value="Sorry, some unknown error occured, please contact support." />
    <add key="Title" value="License Error" />
    <add key="ExemptionId" value="invoice_id" />
    <add key="FullExemption" value="Socinator Pricing" />
    <add key="ExemptionItem" value="invoice-items" />
    <add key="ExemptionTitle" value="item_title" />
    <add key="SelectPackage" value="Select Accounts Package" />
    <add key="CustomExemption" value="Socinator Custom Plan" />
    <add key="ExemptionDescription" value="item_description" />
    <add key="DebugType" value="DS-" />
    <add key="FatalException" value="D-" />
    <add key="GDS" value="Instagram" />
    <add key="FDS" value="Facebook" />
    <add key="TDS" value="Twitter" />
    <add key="LDS" value="LinkedIn" />
    <add key="PDS" value="Pinterest" />
    <add key="GPDS" value="Gplus" />
    <add key="RDS" value="Reddit" />
    <add key="ID" value="Instagram" />
    <add key="FD" value="Facebook" />
    <add key="TD" value="Twitter" />
    <add key="LD" value="LinkedIn" />
    <add key="PD" value="Pinterest" />
    <add key="GD" value="Gplus" />
    <add key="RD" value="Reddit" />
    <add key="ExceptionLogger" value="https://dominatorhouse.com/members/modules/servers/licensing/verify.php" />
    <add key="ExceptionParameter" value="licensekey" />
    <add key="ExceptionEndPoint" value="domain" />
    <add key="ExceptionPoint" value="ip" />
    <add key="ExceptionProx" value="1.1.1.1" />
    <add key="ExceptionPath" value="dir" />
    <add key="ExceptionCall" value="check_token" />
    <add key="ExceptionAlt" value="License" />



    
    
    
    <!--Ends Exemption-->
  </appSettings>
</configuration>

